}

// ── Key handling inside be-body ───────────────────────────────
function beBodyKeydown(e, si){
  // Undo: Ctrl+Z / Cmd+Z
  if((e.ctrlKey||e.metaKey) && e.key==='z' && !e.shiftKey){
    e.preventDefault(); beUndo(si); return;
  }
  // Redo: Ctrl+Y / Cmd+Y / Ctrl+Shift+Z
  if((e.ctrlKey||e.metaKey) && (e.key==='y'||(e.key==='z'&&e.shiftKey))){
    e.preventDefault(); beRedo(si); return;
  }
  // Multi-line selection delete: Backspace or Delete with a range spanning multiple blocks
  if(e.key==='Backspace'||e.key==='Delete'){
    var _sel=window.getSelection();
    if(_sel&&!_sel.isCollapsed&&_sel.rangeCount){
      var _r=_sel.getRangeAt(0);
      var _body=document.querySelector('.be-body[data-si="'+si+'"]');
      if(_body&&_body.contains(_r.commonAncestorContainer)){
        // Walk up from startContainer/endContainer to the direct child of body
        function _topChild(node){
          while(node&&node.parentElement!==_body) node=node.parentElement;
          return node;
        }
        var _sc=_r.startContainer, _ec=_r.endContainer;
        var _startTop=_topChild(_sc.nodeType===3?_sc.parentElement:_sc);
        var _endTop=_topChild(_ec.nodeType===3?_ec.parentElement:_ec);
        if(_startTop&&_endTop&&_startTop!==_endTop){
          e.preventDefault();
          var _kids=Array.from(_body.childNodes);
          var _si2=_kids.indexOf(_startTop), _ei2=_kids.indexOf(_endTop);
          if(_si2<0||_ei2<0||_si2>_ei2){_sel.removeAllRanges();return;}
          var _toDel=_kids.slice(_si2,_ei2+1);
          // Helper: clear a list item's text content but keep checkbox
          function _clearLi(li){
            var _cb=li.querySelector('input[type=checkbox]');
            li.innerHTML='';
            if(_cb){_cb.contentEditable='false';li.appendChild(_cb);}
            li.appendChild(document.createTextNode('\u200b'));
          }
          // Helper: clear a block element
          function _clearBlock(el){
            if(el.tagName==='LI'&&el.classList&&el.classList.contains('be-check-item')) _clearLi(el);
            else el.innerHTML='<br>';
          }
          // Clear the first node (keep it, just wipe its content)
          var _first=_toDel[0];
          if(_first.tagName==='UL'||_first.tagName==='OL'){
            var _fItems=Array.from(_first.children);
            var _scLi2=_sc.nodeType===3?_sc.parentElement:_sc;
            while(_scLi2&&_scLi2.parentElement!==_first) _scLi2=_scLi2.parentElement;
            var _pastStart=false;
            _fItems.forEach(function(li){
              if(li===_scLi2){_pastStart=true; _clearLi(li);}
              else if(_pastStart){_first.removeChild(li);}
            });
            if(!_first.children.length&&_first.parentElement) _first.parentElement.removeChild(_first);
          } else { _clearBlock(_first); }
          // Remove everything in the middle entirely
          for(var _di=1;_di<_toDel.length-1;_di++){
            var _dn=_toDel[_di]; if(_dn.parentElement===_body) _body.removeChild(_dn);
          }
          // Remove the last node entirely (including the end-selection item)
          if(_toDel.length>1){
            var _last=_toDel[_toDel.length-1];
            if(_last.tagName==='UL'||_last.tagName==='OL'){
              // Remove items from start of list UP TO AND INCLUDING the item containing end of selection
              var _lItems=Array.from(_last.children);
              var _ecLi2=_ec.nodeType===3?_ec.parentElement:_ec;
              while(_ecLi2&&_ecLi2.parentElement!==_last) _ecLi2=_ecLi2.parentElement;
              var _doneRemoving=false;
              _lItems.forEach(function(li){
                if(_doneRemoving) return;
                if(li.parentElement) li.parentElement.removeChild(li);
                if(li===_ecLi2) _doneRemoving=true; // remove up to AND including this one
              });
              if(!_last.children.length&&_last.parentElement) _last.parentElement.removeChild(_last);
            } else {
              // Plain block — remove it regardless of parent
              if(_last.parentElement) _last.parentElement.removeChild(_last);
            }
          }
          // Place cursor at end of first surviving block
          var _survivor=_toDel[0];
          if(_survivor.parentElement) placeCaretAtEnd(_survivor);
          else if(_body.lastElementChild) placeCaretAtEnd(_body.lastElementChild);
          _sel.removeAllRanges();
          setTimeout(function(){beSave(si);},0);
          return;
        }
      }
    }
  }
  // Slash command
  if(e.key==='/' && !e.ctrlKey && !e.metaKey){
    var s2=window.getSelection();
    if(s2&&s2.rangeCount){
      var node=s2.getRangeAt(0).startContainer;
      var txt=node.textContent||'';
      if(txt===''||txt.trim()===''){
        // Show slash menu after the / is inserted (use timeout)
        setTimeout(function(){beShowSlashMenu(si,node);},0);
      }
    }
  }
  // Escape closes slash menu
  if(e.key==='Escape'){beHideSlashMenu();return;}
  var s=window.getSelection(); if(!s||!s.rangeCount) return;
  var range=s.getRangeAt(0);
  var body=document.querySelector('.be-body[data-si="'+si+'"]');
  // Find direct child block under cursor
  var node=range.startContainer;
  while(node&&node.parentElement!==body) node=node.parentElement;
  var block=node;

  if(e.key==='Enter'&&!e.shiftKey){
    // Checklist: detect via startContainer
    var _ckNode=range.startContainer;
    var _ckEl=_ckNode.nodeType===3?_ckNode.parentElement:_ckNode;
    // If caret landed on the body at a child index (happens after click-away), resolve to that child
    if(_ckEl===body&&range.startOffset<body.childNodes.length){
      _ckEl=body.childNodes[range.startOffset];
    }
    // Also handle Element node whose startOffset points inside it
    if(_ckEl&&_ckEl.nodeType===1&&_ckEl.classList&&_ckEl.classList.contains('be-checklist')){
      var _ckOffset=range.startOffset;
      _ckEl=_ckEl.children[Math.min(_ckOffset,_ckEl.children.length-1)]||_ckEl.lastElementChild;
    }
    var _ckLi=_ckEl&&_ckEl.closest&&_ckEl.closest('.be-check-item');
    if(_ckLi){
      e.preventDefault();
      var _ckUl=_ckLi.parentElement;
      // Get text content of li minus the checkbox label
      var _ckText=Array.from(_ckLi.childNodes)
        .filter(function(n){return n.nodeType===3||(n.nodeType===1&&n.tagName!=='INPUT');})
        .map(function(n){return n.textContent;}).join('').replace(/​/g,'').trim();
      if(_ckText===''){
        // Empty item → exit checklist
        _ckUl.removeChild(_ckLi);
        if(!_ckUl.children.length&&_ckUl.parentElement) _ckUl.parentElement.removeChild(_ckUl);
        var _ckP=document.createElement('p'); _ckP.innerHTML='<br>';
        if(_ckUl.parentElement&&_ckUl.nextSibling) _ckUl.parentElement.insertBefore(_ckP,_ckUl.nextSibling);
        else body.appendChild(_ckP);
        placeCaretAtEnd(_ckP);
      } else {
        // Has content → add new checklist item
        var _ckItem=beCheckItem(si);
        if(_ckLi.nextSibling) _ckUl.insertBefore(_ckItem.li,_ckLi.nextSibling);
        else _ckUl.appendChild(_ckItem.li);
        _ckItem.li.focus(); placeCaretAtEnd(_ckItem.li);
      }
      setTimeout(function(){beSave(si);},0); return;
    }
    // Empty LI → exit list
    if(block&&block.tagName==='LI'&&block.textContent.trim()===''){
      e.preventDefault();
      var list=block.parentElement; list.removeChild(block);
      if(!list.children.length) body.removeChild(list);
      var p=document.createElement('p'); p.innerHTML='<br>'; body.appendChild(p); placeCaretAtEnd(p);
      setTimeout(function(){beSave(si);},0); return;
    }
    // Table cell navigation
    if(block&&(block.tagName==='TD'||block.tagName==='TH')){
      e.preventDefault();
      var row=block.parentElement; var cells=Array.from(row.cells); var ci=cells.indexOf(block);
      if(ci<cells.length-1){placeCaretAtEnd(cells[ci+1]);return;}
      var nextRow=row.nextElementSibling;
      if(nextRow){placeCaretAtEnd(nextRow.cells[0]);return;}
      // Add row
      var tbl=row.closest('table'); var tbody=tbl.querySelector('tbody')||tbl;
      var tr=document.createElement('tr');
      for(var c=0;c<cells.length;c++){var td=document.createElement('td');td.contentEditable='true';td.innerHTML='<br>';tr.appendChild(td);}
      tbody.appendChild(tr); placeCaretAtEnd(tr.cells[0]);
      setTimeout(function(){beSave(si);},0); return;
    }
    setTimeout(function(){beSave(si);},50);
  }
  if(e.key==='Tab'){
    e.preventDefault();
    // Inside table: move cell
    if(block&&(block.tagName==='TD'||block.tagName==='TH')){
      var row=block.parentElement; var cells=Array.from(row.cells); var ci=cells.indexOf(block);
      var dir=e.shiftKey?-1:1; var next=cells[ci+dir];
      if(next){placeCaretAtEnd(next);return;}
      var adjRow=e.shiftKey?row.previousElementSibling:row.nextElementSibling;
      if(adjRow){placeCaretAtEnd(e.shiftKey?adjRow.cells[adjRow.cells.length-1]:adjRow.cells[0]);return;}
    } else {
      document.execCommand('insertText',false,'  ');
    }
  }
  if(e.key==='Backspace'){
    var _bsNode=range.startContainer;
    var _bsEl=(_bsNode.nodeType===3?_bsNode.parentElement:_bsNode);
    var _bsLi=_bsEl&&_bsEl.closest&&_bsEl.closest('.be-check-item');
    if(_bsLi){
      var _bsText=Array.from(_bsLi.childNodes)
        .filter(function(n){return n.nodeType===3||(n.nodeType===1&&n.tagName!=='INPUT');})
        .map(function(n){return n.textContent;}).join('').replace(/​/g,'').trim();
      if(_bsText===''){
        e.preventDefault();
        var _bsUl=_bsLi.parentElement;
        var _bsPrev=_bsLi.previousElementSibling;
        _bsUl.removeChild(_bsLi);
        if(!_bsUl.children.length&&_bsUl.parentElement) _bsUl.parentElement.removeChild(_bsUl);
        if(_bsPrev){placeCaretAtEnd(_bsPrev);}
        else{var _pb=(_bsUl.parentElement?_bsUl.previousElementSibling:null)||body.lastElementChild;if(_pb)placeCaretAtEnd(_pb);}
        setTimeout(function(){beSave(si);},0); return;
      }
    }
    if(block&&(block.innerHTML==='<br>'||block.textContent==='')){
      var prev=block.previousElementSibling;
      if(prev&&prev!==block){
        e.preventDefault(); body.removeChild(block); placeCaretAtEnd(prev);
        setTimeout(function(){beSave(si);},0);
      }
    }
  }
  // Markdown shortcut: type "- " at start of empty p → bullet
  if(e.key===' '&&block&&block.tagName==='P'){
    var txt=block.textContent;
    // - [ ] or - [x] → checklist item
    if(txt==='- []'||txt==='- [ ]'||txt==='- [x]'||txt==='- [X]'){
      e.preventDefault();
