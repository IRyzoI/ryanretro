        thumb.innerHTML='<span style="color:rgba(255,255,255,0.3);font-size:22px;font-family:Nunito,sans-serif">+</span>';
      }
      thumb.addEventListener('click',function(){
        if(!_tfImages[idx]){thumbFocusUploadSlot(idx);}
        else{_tfIdx=idx;tfRender();}
      });
      strip.appendChild(thumb);
    })(i);
  }
}

function thumbFocusPrev(){_tfIdx=(_tfIdx+3)%4;tfRender();}
