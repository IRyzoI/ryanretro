// ── Flow preview mode ──
var _flowMode = 'preview';
var _previewChecks = {}; // stepIdx_itemIdx -> bool

function mdToCheckItems(md){
  // Parse markdown into a flat list of checkable items, preserving context
  var lines = (md||'').split('\n');
  var items = [];
  var tableHeaders = null;
  for(var i=0;i<lines.length;i++){
    var l = lines[i];
    // Skip table separator rows
    if(/^\|[-| :]+\|/.test(l)) continue;
    // Table header row
    if(/^\|/.test(l)){
      var cells = l.split('|').slice(1,-1).map(function(c){return c.trim();});
      if(!tableHeaders){
        // First table row = header, not a checkable item, store for context
        tableHeaders = cells;
      } else {
        // Data row — make it a checkable item showing cells as "col: val, col: val"
        var label = cells.map(function(c,ci){
          return tableHeaders && tableHeaders[ci] ? '<strong>'+esc(tableHeaders[ci])+':</strong> '+esc(c) : esc(c);
        }).join('  &nbsp;·&nbsp;  ');
        items.push({label: label, raw: l});
      }
      continue;
    } else { tableHeaders = null; }
    // Skip blank lines, headings used as section labels not items
    if(!l.trim()) continue;
    if(/^#{1,3} /.test(l)){
      // Headings become non-checkable section dividers
      items.push({label: '<span style="font-family:Fredoka One,cursive;color:var(--accent);font-size:13px">'+esc(l.replace(/^#+\s*/,''))+'</span>', divider: true});
      continue;
    }
    if(/^---+$/.test(l.trim())){ items.push({divider:true, label:''}); continue; }
    if(/^> /.test(l)){
      items.push({label: '<em style="color:var(--text-muted)">'+esc(l.slice(2))+'</em>', divider:true});
      continue;
    }
    // List items — these are the primary checkables
    var lm = l.match(/^[-*] (\[[ xX]\] )?(.*)/);
    if(lm){
      var pre = lm[1]||'', txt = lm[2];
      var alreadyDone = /[xX]/.test(pre);
      items.push({label: inlineMd(txt), raw: l, defaultDone: alreadyDone});
      continue;
    }
    var om = l.match(/^\d+\.\s+(.*)/);
    if(om){ items.push({label: inlineMd(om[1]), raw: l, defaultDone: false}); continue; }
    // Plain paragraph
    items.push({label: inlineMd(l), raw: l, defaultDone: false});
  }
  return items;
}

function renderFlowPreview(){
  var v = vid(); if(!v) return;
  var preview = document.getElementById('flow-preview');
  var html = (v.flowSteps||[]).map(function(step, si){
    var md = step.md || (Array.isArray(step.bullets)&&step.bullets.length ? step.bullets.map(function(b){return(b.done?'- [x] ':'- ')+b.text;}).join('\n') : '');
    var done = step.done;
    var items = mdToCheckItems(md);
    var itemsHtml = items.map(function(item, ii){
      if(item.divider){
        return item.label
          ? '<div style="padding:6px 0 2px;border-top:'+(ii>0?'1px solid var(--border)':'none')+';margin-top:'+(ii>0?'6px':'0')+'">'+item.label+'</div>'
          : '<hr style="border:none;border-top:1px solid var(--border);margin:6px 0">';
      }
      var key = si+'_'+ii;
      var checked = (_previewChecks[key] !== undefined) ? _previewChecks[key] : !!item.defaultDone;
      return '<label class="fp-check-row" style="opacity:'+(checked?'0.45':'1')+'">'
        + '<input type="checkbox" class="fp-check" '+(checked?'checked':'')+' onchange="togglePreviewCheck('+si+','+ii+',this.checked)" style="accent-color:var(--accent);width:14px;height:14px;flex-shrink:0;cursor:pointer;margin-top:2px">'
        + '<span class="fp-check-label" style="'+(checked?'text-decoration:line-through;':'')+'">'+item.label+'</span>'
        + '</label>';
    }).join('');
    // Step header itself is a checkbox to mark whole step done
    var stepKey = 'step_'+si;
    var stepDone = (_previewChecks[stepKey] !== undefined) ? _previewChecks[stepKey] : done;
    return '<div class="fp-step" style="opacity:'+(stepDone?'0.6':'1')+'">'
      + '<label class="fp-step-header" style="cursor:pointer">'
      +   '<input type="checkbox" class="fp-check" '+(stepDone?'checked':'')+' onchange="togglePreviewStepDone('+si+',this.checked)" style="accent-color:var(--accent);width:15px;height:15px;flex-shrink:0;cursor:pointer">'
      +   '<div class="fp-step-num'+(stepDone?' done':'')+'" style="width:22px;height:22px;font-size:11px">'+( stepDone ? '&#10003;' : (si+1) )+'</div>'
      +   '<div class="fp-step-title">'+esc(step.name)+'</div>'
      + '</label>'
      + (items.length ? '<div class="fp-step-body" style="display:flex;flex-direction:column;gap:4px">'+itemsHtml+'</div>' : '')
      + '</div>';
  }).join('');
  preview.innerHTML = html || '<div style="color:var(--text-muted);font-size:13px;padding:8px">No steps yet.</div>';
}

function togglePreviewCheck(si, ii, checked){
  _previewChecks[si+'_'+ii] = checked;
  // Re-render just this label inline for speed
