        img.title='Click to cycle size (100% → 75% → 50% → 33%)';
        img.draggable=false;
        var sizes=['100%','75%','50%','33%']; var sIdx=0;
        img.addEventListener('click',function(e){
          e.preventDefault(); e.stopPropagation();
          sIdx=(sIdx+1)%sizes.length; img.style.maxWidth=sizes[sIdx]; beSave(si);
        });
        parent.insertBefore(img,placeholder);
        parent.removeChild(placeholder);
        var p=document.createElement('p'); p.innerHTML='<br>';
        if(img.nextSibling) parent.insertBefore(p,img.nextSibling); else parent.appendChild(p);
        placeCaretAtEnd(p); beSave(si);
      }
    }).catch(function(err){
      // Upload failed — fall back to local base64
      console.warn('Imgur upload failed:',err);
      if(placeholder.parentElement) placeholder.parentElement.removeChild(placeholder);
      var reader=new FileReader();
      reader.onload=function(e){
        beInsertImageEl(body,e.target.result,si);
        // Warn user image is local only
        var warn=document.createElement('p');
        warn.style.cssText='color:#ff8070;font-size:11px;margin:0';
        warn.textContent='⚠️ Image stored locally only (ImgBB upload failed: '+err.message+'). Set your ImgBB API key via the \ud83d\uddbc\ufe0f button.';
        var img=body.querySelector('img:last-of-type');
        if(img&&img.nextSibling) body.insertBefore(warn,img.nextSibling); else body.appendChild(warn);
      };
      reader.readAsDataURL(file);
    });
  });
  input.click();
}

// ── Slash command menu ────────────────────────────────────────
