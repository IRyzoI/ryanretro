function beInsertAtCursor(body, newEl){
  var s = window.getSelection();
  if(s && s.rangeCount){
    var range = s.getRangeAt(0);
    // Walk up to find the direct child of body that contains the cursor
    var node = range.startContainer;
    while(node && node.parentElement !== body) node = node.parentElement;
    if(node && node !== body && node.parentElement === body){
      // Insert after the block containing the cursor
      if(node.nextSibling) body.insertBefore(newEl, node.nextSibling);
      else body.appendChild(newEl);
      return;
    }
  }
  // Fallback: append
  body.appendChild(newEl);
}

