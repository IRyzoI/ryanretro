    {name:'Intro',bullets:[b('Introduce the topic'),b('State why it matters to the viewer'),b('Tease what they will find out')],done:false},
    {name:'Main Content',bullets:[b('Cover the core argument or demonstration'),b('Show evidence or footage'),b('Keep energy up — vary the shots')],done:false},
    {name:'Key Takeaways',bullets:[b('Summarise the 2-3 most important points'),b('Make it memorable'),b('Lead naturally into the outro')],done:false}
  ];
