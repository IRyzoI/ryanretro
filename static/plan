      _ul.appendChild(_item.li); _item.span.focus();
      setTimeout(function(){beSave(si);},0); return;
    }
    if(txt==='-'||txt==='*'){
      e.preventDefault(); block.innerHTML='<br>';
      var ul=document.createElement('ul'); var li=document.createElement('li'); li.innerHTML='<br>';
      ul.appendChild(li); body.replaceChild(ul,block); placeCaretAtEnd(li);
      setTimeout(function(){beSave(si);},0); return;
    }
    if(/^#{1,3}$/.test(txt)){
      e.preventDefault();
      var level=txt.length; var hEl=document.createElement('h'+level); hEl.innerHTML='<br>';
      body.replaceChild(hEl,block); placeCaretAtEnd(hEl);
      setTimeout(function(){beSave(si);},0); return;
    }
  }
}

// ── Render a single step as editable block ────────────────────
function renderBeStep(step, si, total){
  var md = step.md||(Array.isArray(step.bullets)&&step.bullets.length?step.bullets.map(function(b){return(b.done?'- [x] ':'- ')+b.text;}).join('\n'):'');
