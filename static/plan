    +'<button class="be-step-num'+(done?' done':'')+'" title="Mark done" onclick="beToggleDone('+si+')">'+( done?'&#10003;':(si+1))+'</button>'
    +'<input class="be-step-title" value="'+esc(step.name)+'" placeholder="Step name" oninput="updStep('+si+',\'name\',this.value)">'
    +'<button class="be-step-del" onclick="beUndo('+si+')" title="Undo (Ctrl+Z)" style="font-size:13px;color:var(--text-muted)">&#8630;</button>'
    +'<button class="be-step-del" onclick="beRedo('+si+')" title="Redo (Ctrl+Y)" style="font-size:13px;color:var(--text-muted)">&#8631;</button>'
    +'<button class="be-step-del" onclick="delStep('+si+')" title="Delete step">&#215;</button>';
  wrap.appendChild(hdr);

  // Editable body
  var body=document.createElement('div'); body.className='be-body'; body.contentEditable='true';
  body.dataset.si=si; body.spellcheck=false;
  body.innerHTML=md.trim()?mdToRichHtml(md):'<p><br></p>';
  // Seed undo stack with initial state
  if(!_undoStack[si]) _undoStack[si]=[];
  _undoStack[si]=[{html:body.innerHTML}];
  _redoStack[si]=[];
  // Make all table cells editable and inject controls
  body.querySelectorAll('table').forEach(function(tbl){
    // Wrap in position:relative div if not already wrapped
    if(!tbl.parentElement.classList.contains('tbl-wrap')){
