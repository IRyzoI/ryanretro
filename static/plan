    beInjectTableControls(tbl);
  });
  // Wire checklist checkbox listeners
  body.querySelectorAll('.be-check-item').forEach(function(li){
    li.contentEditable='true';
    var cb=li.querySelector('input[type=checkbox]');
    if(cb){
      cb.contentEditable='false';
      cb.addEventListener('mousedown',function(e){e.stopPropagation();});
      cb.addEventListener('change',function(){
        li.style.textDecoration=cb.checked?'line-through':'';
        li.style.opacity=cb.checked?'0.5':'1';
        beSave(si);
      });
    }
    // Ensure zero-width spacer exists after checkbox
    if(li.childNodes.length<2||li.childNodes[1].textContent===''){
      li.appendChild(document.createTextNode('​'));
    }
  });
  body.addEventListener('keydown',function(e){beBodyKeydown(e,si);});
  var _t=null;
  body.addEventListener('input',function(){
    clearTimeout(_t); _t=setTimeout(function(){beSave(si);},400);
  });
