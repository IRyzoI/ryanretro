    +'<button class="be-add-btn" onclick="beAddHeading('+si+',2)">+ H2</button>'
    +'<button class="be-add-btn" onclick="beAddHeading('+si+',3)">+ H3</button>'
    +'<button class="be-add-btn" onclick="beAddBulletList('+si+')">+ Bullets</button>'
    +'<button class="be-add-btn" onclick="beAddChecklist('+si+')">+ Checklist</button>'
    +'<button class="be-add-btn" onclick="beAddTable('+si+')">+ Table</button>'
    +'<button class="be-add-btn" onclick="beAddImage('+si+')">+ Image</button>'
    +'<button class="be-add-btn" onclick="beAddDivider('+si+')">+ Divider</button>';
  wrap.appendChild(addBar);
  var hints=document.createElement('div'); hints.className='be-shortcuts';
  hints.innerHTML='<kbd>/</kbd> commands &nbsp;·&nbsp; <kbd>-</kbd>+Space bullet &nbsp;·&nbsp; <kbd>##</kbd>+Space heading &nbsp;·&nbsp; Select text for bold/italic toolbar &nbsp;·&nbsp; Click image to resize';
  wrap.appendChild(hints);

  // Drag events
  wrap.addEventListener('dragstart',function(e){e.dataTransfer.setData('text/plain',si);wrap.style.opacity='0.4';});
  wrap.addEventListener('dragend',function(){wrap.style.opacity='';});
  wrap.addEventListener('dragover',function(e){e.preventDefault();wrap.style.borderColor='var(--accent)';});
  wrap.addEventListener('dragleave',function(){wrap.style.borderColor='';});
  wrap.addEventListener('drop',function(e){
    e.preventDefault();wrap.style.borderColor='';
