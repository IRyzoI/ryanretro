    <div style="margin-left:auto;font-size:11px;color:var(--text-muted);font-weight:700" id="cur-id"></div>
  </div>
  <div class="planner">
    <div class="planner-main">

      <button class="mob-sidebar-toggle" onclick="document.getElementById('p-sidebar').classList.toggle('mob-open')">⚙️ Details & B-Roll</button>
      <div id="p-empty" style="display:flex;flex-direction:column;align-items:center;justify-content:center;flex:1;gap:16px;color:var(--text-muted);text-align:center;padding:60px">
        <div style="font-size:54px;opacity:0.15">🎬</div>
        <div style="font-family:Fredoka One,cursive;font-size:22px;color:var(--text-dim)">No Video Selected</div>
        <div style="font-size:13px;max-width:280px;line-height:1.7">Go to <strong>All Videos</strong> and pick one to open its shooting guide, or create a new one below.</div>
        <div style="display:flex;gap:10px">
          <button class="btns" onclick="gotoView('database',document.getElementById('tab-database'))">← All Videos</button>
          <button class="btnp" onclick="openModal()">＋ New Video</button>
        </div>
      </div>

      <div id="p-content" style="display:none;flex-direction:column;gap:14px">

        <div class="card" style="border-color:var(--border-strong)">
          <div class="card-header"><div class="card-icon">🏆</div><div class="card-label">Hero Title & Thumbnail</div></div>
          <div class="hero">
            <div class="hlabel">Video Title</div>
            <textarea class="htitle" id="f-title" rows="1" placeholder="Your video title here…" oninput="onTitleInput(this)"></textarea>
            <div class="hlabel" style="margin-top:4px">Thumbnail Concept</div>
            <textarea class="hconcept" id="f-concept" rows="2" placeholder="Describe the thumbnail — layout, text, expression, background, colours…" oninput="sf('thumbConcept',this.value)"></textarea>
