// ── Live markdown rendering in rich editor ──
function applyLiveMarkdown(richEl, si){
  // Called on each input — smartly converts completed markdown syntax inline
  var sel = window.getSelection();
  if(!sel||!sel.rangeCount) return;
  var range = sel.getRangeAt(0);
  var node = range.startContainer;
  // Find the current block-level element inside the editor
  var block = node;
  while(block && block.parentElement !== richEl) block = block.parentElement;
  if(!block || block === richEl) return;
  var text = block.textContent || '';
  // Complete table row: starts and ends with |
  if(/^\|.*\|\s*$/.test(text)){
    var cells = text.split('|').slice(1,-1).map(function(c){return c.trim();});
    // Check if next sibling is a separator — if so this is a header
    var next = block.nextSibling;
    var nextText = next ? (next.textContent||'') : '';
    var isSep = /^\|[-| :]+\|/.test(nextText);
    var isHeader = isSep;
    // Check if this line IS a separator
    if(cells.every(function(c){return/^[-: ]+$/.test(c);})){
      // Remove the separator row — it's implicit in our table rendering
      // But we need to trigger a table rebuild — just let the save handle it
      return;
    }
    // Build a mini table or row
    if(isHeader){
      var newEl = document.createElement('table');
      newEl.innerHTML = '<tr>'+cells.map(function(c){return'<th>'+inlineMd(c)+'</th>';}).join('')+'</tr>';
      richEl.replaceChild(newEl, block);
      // Remove separator if present
      if(next && /^\|[-| :]+\|/.test(next.textContent||'')) richEl.removeChild(next);
      // Move cursor to after the table
      var r = document.createRange(); r.setStartAfter(newEl); r.collapse(true);
      sel.removeAllRanges(); sel.addRange(r);
      return;
    } else {
      // Append row to preceding table if exists, else create new table
      var prev = block.previousSibling;
      if(prev && prev.tagName === 'TABLE'){
        var tr = document.createElement('tr');
        tr.innerHTML = cells.map(function(c){return'<td>'+inlineMd(c)+'</td>';}).join('');
        prev.appendChild(tr);
        richEl.removeChild(block);
        var r = document.createRange(); r.setStartAfter(prev); r.collapse(true);
        sel.removeAllRanges(); sel.addRange(r);
        return;
      }
    }
  }
  // Heading: line starting with # and ending with Enter would have created a new block
  // We detect complete headings on the previous block after Enter
  var prev = block.previousSibling;
  if(prev){
    var pt = prev.textContent||'';
    var hm = pt.match(/^(#{1,3}) (.*)/);
    if(hm && prev.tagName !== 'H1' && prev.tagName !== 'H2' && prev.tagName !== 'H3'){
      var tag = 'h'+hm[1].length;
      var newH = document.createElement(tag);
      newH.innerHTML = inlineMd(hm[2]);
      richEl.replaceChild(newH, prev);
    }
    // HR
    if(/^---+$/.test(pt.trim()) && prev.tagName !== 'HR'){
      var hr = document.createElement('hr');
      richEl.replaceChild(hr, prev);
    }
  }
}

// ── Notes renderer ──
function mdToHtml(md){
  if(!md)return'';
  var lines=md.split('\n'),out=[],inTable=false,inUl=false;
  for(var i=0;i<lines.length;i++){
    var l=lines[i];
    // Table row
    if(/^\|/.test(l)){
      var cells=l.split('|').slice(1,-1).map(function(c){return c.trim()});
      if(!inTable){out.push('<table>');inTable=true;}
      // Detect separator row (---|---)
      if(cells.every(function(c){return/^[-:]+$/.test(c)})){continue;}
      // First row of table = header (check if next line is separator)
      var nextLine=lines[i+1]||'';
      var isHeader=!inTable||(/^\|/.test(nextLine)&&nextLine.split('|').slice(1,-1).every(function(c){return/^[-:]+$/.test(c.trim())}));
      if(isHeader&&out[out.length-1]==='<table>'){
        out.push('<tr>'+cells.map(function(c){return'<th>'+inlineMd(c)+'</th>'}).join('')+'</tr>');
      } else {
        out.push('<tr>'+cells.map(function(c){return'<td>'+inlineMd(c)+'</td>'}).join('')+'</tr>');
      }
      continue;
    } else if(inTable){out.push('</table>');inTable=false;}
    // Headings
    if(/^## /.test(l)){if(inUl){out.push('</ul>');inUl=false;}out.push('<h2>'+inlineMd(l.slice(3))+'</h2>');continue;}
    if(/^### /.test(l)){if(inUl){out.push('</ul>');inUl=false;}out.push('<h3>'+inlineMd(l.slice(4))+'</h3>');continue;}
    if(/^# /.test(l)){if(inUl){out.push('</ul>');inUl=false;}out.push('<h2>'+inlineMd(l.slice(2))+'</h2>');continue;}
    // HR
    if(/^[-*]{3,}$/.test(l.trim())){if(inUl){out.push('</ul>');inUl=false;}out.push('<hr>');continue;}
    // List items
    if(/^[-*] /.test(l)){
      if(!inUl){out.push('<ul>');inUl=true;}
      out.push('<li>'+inlineMd(l.slice(2))+'</li>');continue;
    }
    if(inUl){out.push('</ul>');inUl=false;}
    // Blank line
    if(!l.trim()){out.push('<p style="margin:2px 0"></p>');continue;}
    // Normal paragraph
    out.push('<p>'+inlineMd(l)+'</p>');
  }
  if(inTable)out.push('</table>');
  if(inUl)out.push('</ul>');
  return out.join('');
}
function inlineMd(s){
  return s
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>')
    .replace(/\*([^*]+)\*/g,'<em>$1</em>')
    .replace(/`([^`]+)`/g,'<code style="background:var(--surface3);padding:1px 5px;border-radius:4px;font-size:11px">$1</code>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g,'<a href="$2" target="_blank">$1</a>');
}
