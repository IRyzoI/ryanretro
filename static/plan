function mdToRichHtml(md){
  if(!md)return'';
  var lines=(md||'').split('\n'),out=[],inTable=false,inUl=false,inOl=false;
  function closeList(){if(inUl){out.push('</ul>');inUl=false;}if(inOl){out.push('</ol>');inOl=false;}}
  function inl(s){
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>')
      .replace(/__([^_]+)__/g,'<strong>$1</strong>')
      .replace(/\*([^*]+)\*/g,'<em>$1</em>')
      .replace(/_([^_]+)_/g,'<em>$1</em>')
      .replace(/`([^`]+)`/g,'<code>$1</code>')
      .replace(/!\[([^\]]*)\]\(([^)]+)\)/g,'<img src="$2" alt="$1">')
      .replace(/\[([^\]]+)\]\(([^)]+)\)/g,'<a href="$2" target="_blank">$1</a>');
  }
  for(var i=0;i<lines.length;i++){
    var l=lines[i];
    // Table
    if(/^\|/.test(l)){
      var cells=l.split('|').slice(1,-1).map(function(c){return c.trim();});
      if(!inTable){closeList();out.push('<table>');inTable=true;}
      if(cells.every(function(c){return/^[-: ]+$/.test(c);}))continue;
      var nextL=lines[i+1]||'';
      var isTblHdr=out[out.length-1]==='<table>'||(/^\|/.test(nextL)&&nextL.split('|').slice(1,-1).every(function(c){return/^[-: ]+$/.test(c.trim());}));
      if(isTblHdr){out.push('<tr>'+cells.map(function(c){return'<th>'+inl(c)+'</th>';}).join('')+'</tr>');}
      else{out.push('<tr>'+cells.map(function(c){return'<td>'+inl(c)+'</td>';}).join('')+'</tr>');}
      continue;
    }else if(inTable){out.push('</table>');inTable=false;}
    // Headings
    var hm;
    if((hm=l.match(/^(#{1,3}) (.*)/))!=null){closeList();out.push('<h'+hm[1].length+'>'+inl(hm[2])+'</h'+hm[1].length+'>');continue;}
    // HR
    if(/^[-*_]{3,}$/.test(l.trim())){closeList();out.push('<hr>');continue;}
    // Blockquote
    if(/^> /.test(l)){closeList();out.push('<blockquote>'+inl(l.slice(2))+'</blockquote>');continue;}
    // Ordered list
    var om=l.match(/^\d+\. (.*)/);
    if(om){if(inUl){out.push('</ul>');inUl=false;}if(!inOl){out.push('<ol>');inOl=true;}out.push('<li>'+inl(om[1])+'</li>');continue;}
    // Unordered list (- [ ] task syntax too)
    var um=l.match(/^[-*] (\[[ xX]\] )?(.*)/);
    if(um){
      var isTask=(um[1]||'').trim().length>0;
      var taskDone=isTask&&/[xX]/.test(um[1]);
      if(isTask){
        if(inOl){out.push('</ol>');inOl=false;}
        if(!inUl){out.push('<ul class="be-checklist">');inUl=true;}
        var chkAttr=taskDone?' checked':'';
        var listyle=taskDone?' style="text-decoration:line-through;opacity:0.5"':'';
        out.push('<li class="be-check-item" contenteditable="true"'+listyle+'><input type="checkbox" contenteditable="false"'+chkAttr+'>​'+inl(um[2])+'</li>');
      } else {
        if(inOl){out.push('</ol>');inOl=false;}if(!inUl){out.push('<ul>');inUl=true;}
        var done2=/[xX]/.test(um[1]||'');
        out.push('<li'+(done2?' class="done-item"':'')+'>'+inl(um[2])+'</li>');
      }
      continue;
    }
    closeList();
    if(!l.trim()){out.push('<p></p>');continue;}
    out.push('<p>'+inl(l)+'</p>');
  }
  if(inTable)out.push('</table>');
  if(inUl)out.push('</ul>');
  if(inOl)out.push('</ol>');
  return out.join('');
}

function richHtmlToMd(html){
  // Convert rendered HTML back to markdown for storage
  var d=document.createElement('div');d.innerHTML=html;
  function isCtrl(node){
    if(!node||node.nodeType!==1)return false;
    var cl=node.className||'';
    return cl.indexOf('col-resize')>-1||cl.indexOf('tbl-row-panel')>-1||cl.indexOf('tbl-col-panel')>-1||node.getAttribute('data-ctrl')==='1';
  }
  function nodeToMd(node,ctx){
    if(node.nodeType===3)return node.textContent;
    if(isCtrl(node))return ''; // skip ALL control elements before computing kids
    var tag=node.tagName?node.tagName.toLowerCase():'';
    // Skip control children when computing kids
    var kids=Array.from(node.childNodes).filter(function(n){return !isCtrl(n);}).map(function(n){return nodeToMd(n,ctx);}).join('');
    if(tag==='strong'||tag==='b')return'**'+kids+'**';
    if(tag==='em'||tag==='i')return'_'+kids+'_';
    if(tag==='code')return'`'+kids+'`';
    if(tag==='br')return'\n';
    if(tag==='h1')return'# '+kids+'\n';
    if(tag==='h2')return'## '+kids+'\n';
    if(tag==='h3')return'### '+kids+'\n';
    if(tag==='p')return kids+'\n';
    if(tag==='li'){
      var cl=node.className||'';
      if(cl.indexOf('be-check-item')>-1){
        var cb2=node.querySelector('input[type=checkbox]');
        var chked=cb2&&cb2.checked;
        // Text = all text nodes except the checkbox input, minus zero-width spaces
        var txt2=Array.from(node.childNodes)
          .filter(function(n){return n.nodeType===3||(n.nodeType===1&&n.tagName!=='INPUT'&&n.tagName!=='SPAN');})
          .map(function(n){return n.textContent;}).join('').replace(/​/g,'').trim();
        return(chked?'- [x] ':'- [ ] ')+txt2+'\n';
      }
      return(cl.indexOf('done-item')>-1?'- [x] ':'- ')+kids+'\n';
    }
    if(tag==='ul'||tag==='ol')return kids;
    if(tag==='blockquote')return'> '+kids.trim()+'\n';
    if(tag==='hr')return'---\n';
    if(tag==='img')return'!['+node.alt+']('+node.src+')';
    if(tag==='a')return'['+kids+']('+node.href+')';
    // Skip ALL control elements — never serialize them
    if(node.classList&&(node.classList.contains('col-resize')||node.classList.contains('tbl-row-panel')||node.classList.contains('tbl-col-panel')||node.classList.contains('tbl-wrap'))){return'';}
    if(tag==='table'){
      var rows=Array.from(node.rows);
      if(!rows.length)return'';
      var md=[];
      rows.forEach(function(row,ri){
        var cells=Array.from(row.cells).map(function(c){
          // Only get direct text and inline elements — skip any injected divs
          var txt='';
          Array.from(c.childNodes).forEach(function(cn){
            if(cn.nodeType===3){txt+=cn.textContent;}
            else if(cn.nodeType===1){
              var t2=cn.tagName.toLowerCase();
              if(t2==='div'||t2==='span'){
                // skip control divs (col-resize etc), include spans
                if((cn.classList&&(cn.classList.contains('col-resize')||cn.classList.contains('tbl-row-panel')||cn.classList.contains('tbl-col-panel')))||cn.dataset&&cn.dataset.ctrl)return;
              }
              txt+=nodeToMd(cn,'');
            }
          });
          return txt.trim().replace(/\|/g,'\\|').replace(/\n/g,' ');
        });
        md.push('| '+cells.join(' | ')+' |');
        if(ri===0)md.push('| '+cells.map(function(){return'---';}).join(' | ')+' |');
      });
      return md.join('\n')+'\n';
    }
    // Wrapper divs — only recurse into table children, skip panel siblings
    if(tag==='div'){
      var out='';
      Array.from(node.childNodes).forEach(function(cn){
        if(cn.nodeType===1&&cn.classList&&(cn.classList.contains('tbl-row-panel')||cn.classList.contains('tbl-col-panel')))return;
        out+=nodeToMd(cn,'');
      });
      return out;
    }
    return kids;
  }
  return Array.from(d.childNodes).map(function(n){return nodeToMd(n,'');}).join('').replace(/\n\n+/g,'\n\n').trim();
}

