function closeThumbnailFocus(){
  document.getElementById('thumb-focus-modal').style.display='none';
}

function tfRender(){
  var img=document.getElementById('tf-main-img');
  var empty=document.getElementById('tf-empty-slot');
  var cur=_tfImages[_tfIdx];
  if(cur){
    img.src=cur; img.style.display='block'; empty.style.display='none';
  } else {
    img.style.display='none'; empty.style.display='flex';
  }
  // Render strip
  var strip=document.getElementById('tf-strip'); strip.innerHTML='';
  for(var i=0;i<4;i++){
    (function(idx){
      var thumb=document.createElement('div');
      thumb.style.cssText='width:120px;aspect-ratio:16/9;border-radius:6px;overflow:hidden;cursor:pointer;border:3px solid '+(idx===_tfIdx?'var(--accent)':'rgba(255,255,255,0.15)')+';transition:border-color 0.15s;flex-shrink:0;position:relative;background:rgba(255,255,255,0.05)';
      if(_tfImages[idx]){
