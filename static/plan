  if (!v) return;

  if (dumpResult.hook) { v.hook = dumpResult.hook; var hel=document.getElementById('f-hook'); if(hel){hel.value=dumpResult.hook;autoH(hel);} }
  if (dumpResult.outro) { v.outro = dumpResult.outro; var oel=document.getElementById('f-outro'); if(oel){oel.value=dumpResult.outro;autoH(oel);} }
  if (dumpResult.seoTitle) { v.seoTitle = dumpResult.seoTitle; var sel=document.getElementById('f-seo'); if(sel)sel.value=dumpResult.seoTitle; }

  // Full flow step rewrite — replace all steps with new ones
  if (dumpResult.flowSteps && dumpResult.flowSteps.length) {
    v.flowSteps = dumpResult.flowSteps.map(function(s){
      return { name: s.name, md: s.md||'', bullets: [], done: false };
    });
    if(_flowMode==='preview')renderBeEditor();
    else if(_flowMode==='shooting')renderFlowPreview();
  }

  if (dumpResult.broll && dumpResult.broll.length) {
    // Merge — add any that don't already exist
    if (!v.broll) v.broll = [];
    var existing = v.broll.map(function(b){return b.text.toLowerCase();});
    dumpResult.broll.forEach(function(b){
      if (!existing.includes(b.toLowerCase())) v.broll.push({text:b, done:false});
    });
    renderBroll(v.broll);
  }

  var cleaned = dumpResult.cleanedNotes || '';
  v.notes = cleaned;
  document.getElementById('f-notes').value = cleaned;
  autoH(document.getElementById('f-notes'));

  persist();
  document.getElementById('dump-preview').style.display = 'none';
  document.getElementById('dump-status').textContent = '\u2713 Applied!';
  dumpResult = null;
  setTimeout(function(){ document.getElementById('dump-status').textContent = ''; }, 3000);
}

