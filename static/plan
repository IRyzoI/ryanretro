    }
  } catch(e){
    status.textContent = '\u274c '+e.message;
  }
}

// Push local data to Gist
async function ghFetch(url, opts){
  // Try direct first (works when hosted via https), fall back to CORS proxy
  try {
    var r = await fetch(url, opts);
    if(r.status !== 0) return r; // 0 = network error / CORS block
    throw new Error('blocked');
  } catch(e) {
    var proxy = 'https://corsproxy.io/?' + encodeURIComponent(url);
    return fetch(proxy, opts);
  }
}

async function gistPush(forceCreate){
  if(!_gistToken || _syncing) return;
  _syncing = true;
  setSyncStatus('\u23f3 Syncing\u2026');
  try {
    var payload = JSON.stringify(videos, null, 0);
    var body = { description:'RyanRetro Hub Data', public:false,
      files:{ 'ryanretro-hub.json':{ content: payload } } };
    var headers = {'Authorization':'token '+_gistToken,'Content-Type':'application/json','Accept':'application/vnd.github.v3+json'};
    var r;
    if(_gistId && !forceCreate){
      r = await ghFetch('https://api.github.com/gists/'+_gistId,
        {method:'PATCH', headers:headers, body:JSON.stringify(body)});
    } else {
      r = await ghFetch('https://api.github.com/gists',
        {method:'POST', headers:headers, body:JSON.stringify(body)});
    }
    if(!r.ok){ var e=await r.json(); throw new Error(e.message||'HTTP '+r.status); }
    var data = await r.json();
    if(data.id && data.id !== _gistId){
      _gistId = data.id;
      localStorage.setItem('rr_gist_id', _gistId);
    }
    var t = new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
    setSyncStatus('\u2601 Synced '+t, 'var(--text-muted)');
  } catch(e){
    setSyncStatus('\u26a0 Sync failed', '#ff8070');
    console.warn('Gist push failed:', e);
  }
  _syncing = false;
}

// Debounced push — fires 3s after last change
function gistSchedule(){
  if(!_gistToken) return;
  clearTimeout(_syncTimer);
  _syncTimer = setTimeout(gistPush, 3000);
}

// Pull from Gist on load — merge if Gist is newer
async function gistPull(){
  if(!_gistToken || !_gistId) return;
  setSyncStatus('\u23f3 Loading\u2026');
  try {
    var r = await ghFetch('https://api.github.com/gists/'+_gistId, {
      headers:{'Authorization':'token '+_gistToken,'Accept':'application/vnd.github.v3+json'}
    });
    if(!r.ok) throw new Error('HTTP '+r.status);
    var data = await r.json();
    var file = data.files && data.files['ryanretro-hub.json'];
    if(!file) throw new Error('No data file in Gist');
    var content = file.content;
    if(file.truncated){
      // fetch raw if truncated
      var r2 = await fetch(file.raw_url);
      content = await r2.text();
    }
    var remote = JSON.parse(content);
    if(!Array.isArray(remote)) throw new Error('Invalid data');
    // Simple merge: use remote if it has more recent data
    // Strategy: replace local with remote, then persist
    videos = remote;
    try{ localStorage.setItem('rr_hub_v6', JSON.stringify(remote)); }catch(e){}
    renderDB();
    if(currentId){ var v=videos.find(function(x){return x.id===currentId;}); if(v)loadPlanner(currentId); }
    var t = new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
    setSyncStatus('\u2601 Synced '+t, 'var(--text-muted)');
  } catch(e){
    setSyncStatus('\u26a0 Sync error', '#ff8070');
    console.warn('Gist pull failed:', e);
  }
}

// Init: pull on load if token exists
(function gistInit(){
  if(_gistToken && _gistId){
    gistPull();
  } else if(_gistToken){
    setSyncStatus('\u26a0 Needs setup', '#ff8070');
  }
})();

