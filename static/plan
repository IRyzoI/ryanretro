function _handleRichToolbar(e){
  var btn=e.target.closest('[data-cmd]');if(!btn)return;
  e.preventDefault();
  var cmd=btn.dataset.cmd;
  if(cmd==='bold')document.execCommand('bold');
  else if(cmd==='italic')document.execCommand('italic');
  else if(cmd==='code'){wrapSel('`','`');}
  else if(cmd==='h2'){insertLinePrefix('## ');}
  else if(cmd==='h3'){insertLinePrefix('### ');}
  else if(cmd==='ul'){insertLinePrefix('- ');}
  else if(cmd==='ol'){insertLinePrefix('1. ');}
  else if(cmd==='task'){insertLinePrefix('- [ ] ');}
  else if(cmd==='table'){insertTable(3);}
  else if(cmd==='hr'){insertLinePrefix('---');}
  else if(cmd==='img'){insertImage();}
}

function wrapSel(before,after){
  var s=window.getSelection();if(!s.rangeCount)return;
  var r=s.getRangeAt(0),t=r.toString();
  var node=document.createTextNode(before+t+after);
  r.deleteContents();r.insertNode(node);
  s.removeAllRanges();var nr=document.createRange();
  nr.setStart(node,before.length);nr.setEnd(node,before.length+t.length);s.addRange(nr);
}
function insertLinePrefix(prefix){
  document.execCommand('insertText',false,prefix);
}
function insertTable(cols){
  var hdr='| '+Array(cols).fill('Header').join(' | ')+' |\n';
  var sep='| '+Array(cols).fill('---').join(' | ')+' |\n';
  var row='| '+Array(cols).fill('Cell').join(' | ')+' |\n';
  document.execCommand('insertText',false,'\n'+hdr+sep+row+row);
}
var _savedRange = null;
function saveSelection(){
  var s=window.getSelection();
  if(s&&s.rangeCount){ _savedRange=s.getRangeAt(0).cloneRange(); }
}
function restoreSelection(){
  if(!_savedRange)return;
  var s=window.getSelection();s.removeAllRanges();s.addRange(_savedRange);
}
function insertImage(){
  saveSelection();
  var url=prompt('Image URL:');if(!url)return;
  restoreSelection();
  document.execCommand('insertText',false,'![image]('+url+')');
}

// ── WYSIWYG helpers ──
function getCaretBlock(el){
  var s=window.getSelection();if(!s||!s.rangeCount)return null;
  var node=s.getRangeAt(0).startContainer;
  while(node&&node.parentElement!==el)node=node.parentElement;
  return(node&&node!==el)?node:null;
}
function placeCaretAtEnd(node){
  var s=window.getSelection();s.removeAllRanges();
  var r=document.createRange();r.selectNodeContents(node);r.collapse(false);s.addRange(r);
}
function placeCaretAfterNode(node){
  var s=window.getSelection();s.removeAllRanges();
  var r=document.createRange();r.setStartAfter(node);r.collapse(true);s.addRange(r);
}
function insertAfter(ref,newEl,parent){
  if(ref.nextSibling)parent.insertBefore(newEl,ref.nextSibling);else parent.appendChild(newEl);
}
function wysiwygSave(editor,si){
  var v=vid();if(!v)return;
  v.flowSteps[si].md=richHtmlToMd(editor.innerHTML);
  v.flowSteps[si].bullets=[];persist();
}

function wysiwygKeydown(e,editor,si){
  var s=window.getSelection();if(!s||!s.rangeCount)return;
  var range=s.getRangeAt(0);
  var block=getCaretBlock(editor);
  var text=block?block.textContent:'';

  if(e.key==='Enter'&&!e.shiftKey){
    // Empty list item → exit list
    if(block&&block.tagName==='LI'&&text.trim()===''){
      e.preventDefault();
      var list=block.parentElement;
      list.removeChild(block);
      if(!list.children.length&&list.parentElement)list.parentElement.removeChild(list);
      var p=document.createElement('p');p.innerHTML='<br>';
      editor.appendChild(p);placeCaretAtEnd(p);
      setTimeout(function(){wysiwygSave(editor,si);},0);return;
    }
    // Table cell → next cell or new row
    if(block&&(block.tagName==='TD'||block.tagName==='TH')){
      e.preventDefault();
      var row=block.parentElement;var cells=Array.from(row.cells);var idx=cells.indexOf(block);
      if(idx<cells.length-1){placeCaretAtEnd(cells[idx+1]);return;}
      var nextRow=row.nextElementSibling;
      if(nextRow){placeCaretAtEnd(nextRow.cells[0]);return;}
      var table=row.closest('table');
      var newRow=table.insertRow(-1);
      for(var ci=0;ci<cells.length;ci++){var td=newRow.insertCell(-1);td.innerHTML='<br>';}
      placeCaretAtEnd(newRow.cells[0]);
      setTimeout(function(){wysiwygSave(editor,si);},0);return;
    }
    // Markdown triggers on current line
    if(block){
      var caret=range.startOffset;
      var tn=block.firstChild;
      var lineText=(tn&&tn.nodeType===3)?tn.textContent.slice(0,caret):text;
      // Heading
      var hm=lineText.match(/^(#{1,3}) (.+)$/);
      if(hm){
        e.preventDefault();
        var tag='h'+hm[1].length;var newH=document.createElement(tag);newH.textContent=hm[2];
        editor.replaceChild(newH,block);
        var p=document.createElement('p');p.innerHTML='<br>';insertAfter(newH,p,editor);placeCaretAtEnd(p);
        setTimeout(function(){wysiwygSave(editor,si);},0);return;
      }
      // HR
      if(lineText.trim()==='---'){
        e.preventDefault();
        var hr=document.createElement('hr');editor.replaceChild(hr,block);
        var p=document.createElement('p');p.innerHTML='<br>';insertAfter(hr,p,editor);placeCaretAtEnd(p);
        setTimeout(function(){wysiwygSave(editor,si);},0);return;
      }
      // Blockquote
      var bqm=lineText.match(/^> (.+)$/);
      if(bqm){
        e.preventDefault();
        var bq=document.createElement('blockquote');bq.textContent=bqm[1];
        editor.replaceChild(bq,block);
        var p=document.createElement('p');p.innerHTML='<br>';insertAfter(bq,p,editor);placeCaretAtEnd(p);
        setTimeout(function(){wysiwygSave(editor,si);},0);return;
      }
      // Table row: | col | col |
      if(/^\|.*\|$/.test(lineText.trim())){
        e.preventDefault();
        var cols=lineText.split('|').slice(1,-1).map(function(c){return c.trim();});
        var isSep=cols.every(function(c){return/^[-: ]+$/.test(c);});
        var prev=block.previousElementSibling;
        if(isSep&&prev&&prev.tagName==='TABLE'){
          // Convert last row of table to header
          editor.removeChild(block);
          var tbl=prev;var lastRow=tbl.rows[tbl.rows.length-1];
          var thead=tbl.querySelector('thead')||document.createElement('thead');
          var hrow=document.createElement('tr');
          Array.from(lastRow.cells).forEach(function(td){
            var th=document.createElement('th');th.textContent=td.textContent;hrow.appendChild(th);
          });
          thead.innerHTML='';thead.appendChild(hrow);
          tbl.insertBefore(thead,tbl.firstChild);
          // Remove the last row which is now the header
          tbl.deleteRow(tbl.rows.length-1);
          var p=document.createElement('p');p.innerHTML='<br>';insertAfter(tbl,p,editor);
          placeCaretAtEnd(p);
          setTimeout(function(){wysiwygSave(editor,si);},0);return;
        }
        if(prev&&prev.tagName==='TABLE'){
          // Add data row to existing table
          var tbody=prev.querySelector('tbody')||prev;
          var tr=document.createElement('tr');
          cols.forEach(function(c){var td=document.createElement('td');td.textContent=c;tr.appendChild(td);});
          tbody.appendChild(tr);editor.removeChild(block);
          var p=document.createElement('p');p.innerHTML='<br>';insertAfter(prev,p,editor);
          placeCaretAtEnd(tr.cells[0]);
          setTimeout(function(){wysiwygSave(editor,si);},0);return;
        }
        // New table
        var tbl=document.createElement('table');
        var tbody=document.createElement('tbody');
        var tr=document.createElement('tr');
        cols.forEach(function(c){var td=document.createElement('td');td.textContent=c;tr.appendChild(td);});
        tbody.appendChild(tr);tbl.appendChild(tbody);
        editor.replaceChild(tbl,block);
        var p=document.createElement('p');p.innerHTML='<br>';insertAfter(tbl,p,editor);
        placeCaretAtEnd(tr.cells[0]);
        setTimeout(function(){wysiwygSave(editor,si);},0);return;
      }
      // Bullet list
      var ulm=lineText.match(/^[-*] (\[[ xX]\] )?(.*)$/);
      if(ulm){
        e.preventDefault();
        var done=/[xX]/.test(ulm[1]||'');var txt=ulm[2];
        var prev=block.previousElementSibling;
        var ul=(prev&&prev.tagName==='UL')?prev:(function(){var u=document.createElement('ul');editor.replaceChild(u,block);return u;})();
        if(prev&&prev.tagName==='UL')editor.removeChild(block);
        var li=document.createElement('li');li.textContent=txt;
        if(done)li.style.textDecoration='line-through';
        ul.appendChild(li);
        var p=document.createElement('p');p.innerHTML='<br>';insertAfter(ul,p,editor);
        placeCaretAtEnd(li);
        setTimeout(function(){wysiwygSave(editor,si);},0);return;
      }
      // Ordered list
      var olm=lineText.match(/^\d+\. (.+)$/);
      if(olm){
        e.preventDefault();
        var prev=block.previousElementSibling;
        var ol=(prev&&prev.tagName==='OL')?prev:(function(){var o=document.createElement('ol');editor.replaceChild(o,block);return o;})();
        if(prev&&prev.tagName==='OL')editor.removeChild(block);
        var li=document.createElement('li');li.textContent=olm[1];ol.appendChild(li);
        var p=document.createElement('p');p.innerHTML='<br>';insertAfter(ol,p,editor);
        placeCaretAtEnd(li);
        setTimeout(function(){wysiwygSave(editor,si);},0);return;
      }
    }
    setTimeout(function(){wysiwygSave(editor,si);},50);
    return;
  }

  if(e.key==='Tab'){
    e.preventDefault();
    document.execCommand('insertText',false,'  ');
    setTimeout(function(){wysiwygSave(editor,si);},0);
  }

  if(e.key==='Backspace'&&block){
    if(text===''||(block.innerHTML==='<br>')){
      var prev=block.previousElementSibling;
      if(prev){
        e.preventDefault();editor.removeChild(block);placeCaretAtEnd(prev);
        setTimeout(function(){wysiwygSave(editor,si);},0);
      }
    }
  }
}

function wysiwygInput(editor,si){
  var s=window.getSelection();if(!s||!s.rangeCount)return;
  var block=getCaretBlock(editor);if(!block)return;
  var tn=block.firstChild;if(!tn||tn.nodeType!==3)return;
  var text=tn.textContent;
  // Bold **word**
  var bm=text.match(/^(.*)\*\*([^*]+)\*\*(.*)$/);
  if(bm){
    block.innerHTML='';
    if(bm[1])block.appendChild(document.createTextNode(bm[1]));
    var strong=document.createElement('strong');strong.textContent=bm[2];block.appendChild(strong);
    if(bm[3])block.appendChild(document.createTextNode(bm[3]));
    placeCaretAtEnd(bm[3]?block.lastChild:strong);return;
  }
  // Italic *word*
  var im=text.match(/^(.*[^*])\*([^*]+)\*([^*].*)$|^\*([^*]+)\*(.*)$/);
  if(im&&!text.includes('**')){
    var before=im[1]||'',word=im[2]||im[4],after=im[3]||im[5]||'';
    block.innerHTML='';
    if(before)block.appendChild(document.createTextNode(before));
    var em=document.createElement('em');em.textContent=word;block.appendChild(em);
    if(after)block.appendChild(document.createTextNode(after));
    placeCaretAtEnd(after?block.lastChild:em);return;
  }
  // Code `word`
  var cm=text.match(/^(.*)`([^`]+)`(.*)$/);
  if(cm){
    block.innerHTML='';
    if(cm[1])block.appendChild(document.createTextNode(cm[1]));
    var code=document.createElement('code');code.textContent=cm[2];block.appendChild(code);
    if(cm[3])block.appendChild(document.createTextNode(cm[3]));
    placeCaretAtEnd(cm[3]?block.lastChild:code);return;
  }
  clearTimeout(editor._t);editor._t=setTimeout(function(){wysiwygSave(editor,si);},500);
}

function makeWysiwyg(container,mdContent,si){
  var editor=document.createElement('div');
  editor.className='wysiwyg';editor.contentEditable='true';
  editor.setAttribute('data-ph','Type here \u2014 - for bullet, ## for heading, | col | col | for table, **bold**, _italic_, `code`');
  editor.spellcheck=false;
  editor.innerHTML=mdContent.trim()?mdToRichHtml(mdContent):'<p><br></p>';
  editor.addEventListener('keydown',function(e){wysiwygKeydown(e,editor,si);});
  editor.addEventListener('input',function(){wysiwygInput(editor,si);});
  editor.addEventListener('paste',function(e){
    e.preventDefault();
    var txt=(e.clipboardData||window.clipboardData).getData('text/plain');
    document.execCommand('insertText',false,txt);
  });
  container.appendChild(editor);
  return editor;
}

