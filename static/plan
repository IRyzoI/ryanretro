async function openThumbnailFocus(){
  var v=vid(); if(!v)return;
  _tfVideoId=v.id;
  // Load all 4 slots from IndexedDB
  for(var i=0;i<4;i++) _tfImages[i]=await iGet(ik(v.id,i))||null;
