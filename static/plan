// ── Undo/Redo history per step ───────────────────────────────
var _undoStack = {}; // si -> [{html, md}]
var _redoStack = {}; // si -> [{html, md}]
var _undoSaving = false;

function bePushUndo(si, html){
  if(_undoSaving) return;
  if(!_undoStack[si]) _undoStack[si]=[];
  var last = _undoStack[si][_undoStack[si].length-1];
  if(last && last.html === html) return; // no change
  _undoStack[si].push({html:html});
  if(_undoStack[si].length > 50) _undoStack[si].shift();
  _redoStack[si] = []; // clear redo on new action
}

function beUndo(si){
  var body = document.querySelector('.be-body[data-si="'+si+'"]'); if(!body)return;
  if(!_undoStack[si]||_undoStack[si].length<2) return;
  // Push current to redo
  if(!_redoStack[si]) _redoStack[si]=[];
  _redoStack[si].push({html:body.innerHTML});
  _undoStack[si].pop(); // remove current
  var prev = _undoStack[si][_undoStack[si].length-1];
  _undoSaving=true;
  body.innerHTML = prev.html;
  body.querySelectorAll('table').forEach(function(t){beInjectTableControls(t);});
  _undoSaving=false;
  var v=vid(); if(v){v.flowSteps[si].md=richHtmlToMd(prev.html);v.flowSteps[si].bullets=[];persist();}
}

function beRedo(si){
  var body = document.querySelector('.be-body[data-si="'+si+'"]'); if(!body)return;
  if(!_redoStack[si]||!_redoStack[si].length) return;
  var next = _redoStack[si].pop();
  if(!_undoStack[si]) _undoStack[si]=[];
  _undoStack[si].push({html:body.innerHTML});
  _undoSaving=true;
  body.innerHTML = next.html;
  body.querySelectorAll('table').forEach(function(t){beInjectTableControls(t);});
  _undoSaving=false;
  var v=vid(); if(v){v.flowSteps[si].md=richHtmlToMd(next.html);v.flowSteps[si].bullets=[];persist();}
}

function beSave(si){
  var v=vid(); if(!v) return;
  var body = document.querySelector('.be-body[data-si="'+si+'"]');
  if(!body) return;
  bePushUndo(si, body.innerHTML);
  v.flowSteps[si].md = richHtmlToMd(safeBodyHtml(body));
  v.flowSteps[si].bullets = [];
  persist();
}

