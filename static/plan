      {name:'Display',bullets:[b('Show brightness test with meter'),b('Compare colour and sharpness'),b('Note any PWM or coating differences')],done:false},
      {name:'Performance',bullets:[b('Test same games on both'),b('Show frame rate results'),b('Note where each pulls ahead')],done:false},
      {name:'Battery & Thermals',bullets:[b('State real-world battery figures'),b('Show thermal camera reading'),b('Note heat during sustained play')],done:false},
