<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RyanRetro — Content Hub</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}

body.theme-pastel{
  --bg:#FDF8EF;--surface:#FFFDF7;--surface2:#FFF7E0;--surface3:#FEF0C4;
  --accent:#F5C842;--accent2:#F4956A;--accent-text:#4A3800;
  --text:#3D3422;--text-dim:#7A6E58;--text-muted:#B5A98A;
  --border:#E8D08A;--border-strong:#C8A830;
  --shadow:0 2px 12px rgba(180,140,40,0.10);
  --red:#D96060;--green:#5CB85C;--blue:#5B9FD8;
  --ti-bg:#DCF0FF;--ti-c:#1A66AA;
  --ts-bg:#FFF3CC;--ts-c:#7A5500;
  --tf-bg:#FFE8D4;--tf-c:#8A3800;
  --te-bg:#EEE0FF;--te-c:#5520AA;
  --tp-bg:#D4FFD4;--tp-c:#1A6B1A;
  --r:14px;--rl:20px;--rx:26px;
}
body.theme-retro{
  --bg:#13131A;--surface:#1C1C27;--surface2:#242433;--surface3:#2C2C3E;
  --accent:#A18DE3;--accent2:#E3918D;--accent-text:#ffffff;
  --text:#F0EEF8;--text-dim:#9B99B2;--text-muted:#6B697F;
  --border:rgba(161,141,227,0.22);--border-strong:rgba(161,141,227,0.5);
  --shadow:0 2px 16px rgba(0,0,0,0.4);
  --red:#E2566A;--green:#5DCB8C;--blue:#5BA3F5;
  --ti-bg:rgba(91,163,245,0.18);--ti-c:#5BA3F5;
  --ts-bg:rgba(245,197,66,0.18);--ts-c:#F5C542;
  --tf-bg:rgba(161,141,227,0.18);--tf-c:#A18DE3;
  --te-bg:rgba(245,166,35,0.18);--te-c:#F5A623;
  --tp-bg:rgba(93,203,140,0.18);--tp-c:#5DCB8C;
  --r:10px;--rl:16px;--rx:20px;
}

html{height:100%}body{min-height:100%;overflow-x:hidden}@media(max-width:700px){body{overflow:auto}.hub{min-height:100vh;height:auto}.view.active{overflow:visible}}
body{color:var(--text);font-family:Nunito,sans-serif;background:var(--bg);transition:background 0.3s}
.hub{display:flex;flex-direction:column;height:100vh;min-height:100vh}

/* NAV */
.nav{display:flex;align-items:center;gap:0;background:var(--surface);border-bottom:2px solid var(--border);padding:0 16px;flex-shrink:0;height:54px;box-shadow:var(--shadow)}
.nav-logo{font-family:Fredoka One,cursive;font-size:18px;background:var(--accent);color:var(--accent-text);border-radius:50px;padding:4px 14px;margin-right:12px;white-space:nowrap;letter-spacing:0.3px}
.nav-sub{color:var(--text-muted);font-size:12px;font-weight:800;margin-right:14px;letter-spacing:0.3px}
.nav-tabs{display:flex;gap:4px;flex:1}
.nav-tab{background:none;border:2px solid transparent;color:var(--text-dim);font-family:Nunito,sans-serif;font-size:13px;font-weight:800;padding:5px 14px;border-radius:50px;cursor:pointer;transition:all 0.15s;white-space:nowrap}
.nav-tab:hover{color:var(--text);background:var(--surface2)}
.nav-tab.active{color:var(--text);background:var(--surface3);border-color:var(--border-strong)}
.nav-right{display:flex;align-items:center;gap:8px;margin-left:auto}
.theme-btn{background:var(--surface2);border:2px solid var(--border);color:var(--text-dim);font-family:Nunito,sans-serif;font-weight:800;font-size:11px;padding:5px 12px;border-radius:50px;cursor:pointer;transition:all 0.15s;white-space:nowrap}
.theme-btn:hover{border-color:var(--border-strong);color:var(--text)}
.nav-add{background:var(--accent);color:var(--accent-text);border:none;font-family:Nunito,sans-serif;font-weight:800;font-size:13px;padding:7px 16px;border-radius:50px;cursor:pointer;white-space:nowrap;transition:opacity 0.15s;box-shadow:0 2px 8px rgba(0,0,0,0.1)}
.nav-add:hover{opacity:0.85}

/* VIEWS */
.view{display:none;flex:1;overflow:hidden}
.view.active{display:flex;flex-direction:column}

/* PLANNER */
.planner-topbar{display:flex;align-items:center;gap:10px;background:var(--surface);border-bottom:2px solid var(--border);padding:9px 16px;flex-shrink:0}
.back-btn{display:flex;align-items:center;gap:5px;background:var(--surface2);border:2px solid var(--border);color:var(--text-dim);font-family:Nunito,sans-serif;font-weight:800;font-size:12px;padding:5px 12px;border-radius:50px;cursor:pointer;transition:all 0.15s;white-space:nowrap}
.back-btn:hover{border-color:var(--border-strong);color:var(--text)}
.planner-cur-title{font-family:Fredoka One,cursive;font-size:15px;color:var(--text-dim);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:380px}
.planner{display:grid;grid-template-columns:1fr 296px;flex:1;overflow:hidden}
.planner-main{overflow-y:auto;padding:18px;display:flex;flex-direction:column;gap:14px;border-right:2px solid var(--border)}
.planner-sidebar{overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:12px;background:var(--surface)}

/* Cards */
.card{background:var(--surface);border:2px solid var(--border);border-radius:var(--rx);padding:16px;display:flex;flex-direction:column;gap:10px;box-shadow:var(--shadow)}
.card-header{display:flex;align-items:center;gap:8px}
.card-icon{width:30px;height:30px;border-radius:50%;background:var(--surface3);border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.card-label{font-size:11px;font-weight:800;letter-spacing:1px;color:var(--accent2);text-transform:uppercase}
body.theme-retro .card-label{color:var(--accent)}
.field{background:var(--surface2);border:2px solid var(--border);border-radius:var(--r);padding:10px 12px;color:var(--text);font-family:Nunito,sans-serif;font-size:13px;width:100%;outline:none;resize:vertical;line-height:1.6;transition:border-color 0.15s;overflow:hidden;field-sizing:content}
.field:focus{border-color:var(--border-strong)}
.field::placeholder{color:var(--text-muted)}

/* Hero */
.hero{background:var(--surface2);border:2px dashed var(--border-strong);border-radius:var(--rx);padding:18px;display:flex;flex-direction:column;gap:10px;transition:border-color 0.2s}
.hero:hover{border-color:var(--accent)}
.hlabel{font-size:10px;font-weight:800;letter-spacing:1.5px;color:var(--text-muted);text-transform:uppercase}
.htitle{background:none;border:none;color:var(--text);font-family:Fredoka One,cursive;font-size:28px;width:100%;outline:none;line-height:1.2;resize:none;overflow:hidden;field-sizing:content;min-height:38px}
.htitle::placeholder{color:var(--text-muted);opacity:0.45}
.hconcept{background:none;border:none;color:var(--text-dim);font-family:Nunito,sans-serif;font-size:13px;width:100%;outline:none;resize:vertical;min-height:60px;line-height:1.6;overflow:hidden;field-sizing:content}
.hconcept::placeholder{color:var(--text-muted);opacity:0.45}
.thumbdrop{background:var(--surface3);border:2px dashed var(--border);border-radius:var(--rl);aspect-ratio:16/9;width:100%;display:flex;align-items:center;justify-content:center;color:var(--text-muted);font-size:12px;gap:6px;cursor:pointer;transition:all 0.2s;flex-direction:column;overflow:hidden;position:relative}
.thumbdrop:hover{border-color:var(--accent)}
.thumbdrop img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:calc(var(--rl) - 2px)}

/* Flow */
.flow-steps{display:flex;flex-direction:column;gap:6px}
.step{background:var(--surface2);border:2px solid var(--border);border-radius:var(--rl);display:flex;align-items:flex-start;gap:10px;padding:10px 12px;cursor:grab;transition:all 0.15s;user-select:none}
.step:hover{border-color:var(--border-strong);box-shadow:var(--shadow)}
.step.dragging{opacity:0.4;border-style:dashed}
.step.dragover{border-color:var(--accent);background:var(--surface3)}
.step-num{width:28px;height:28px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;color:var(--accent-text);flex-shrink:0;margin-top:2px;border:none;cursor:pointer;transition:all 0.18s;padding:0}
.step-num:hover{transform:scale(1.12)}
.step-num.step-done{background:var(--green);color:#fff;text-decoration:none}
.step-body-done .step-name{text-decoration:line-through;opacity:0.45}
.step-body-done .step-detail{opacity:0.35}
.step-body{flex:1;display:flex;flex-direction:column;gap:4px}
.step-name{font-size:13px;font-weight:800;color:var(--text);background:none;border:none;outline:none;font-family:Nunito,sans-serif;width:100%}
.step-bullets{display:flex;flex-direction:column;gap:3px;margin-top:2px}
.step-bullet{display:flex;align-items:flex-start;gap:7px}
.step-bullet-check{width:15px;height:15px;accent-color:var(--accent);cursor:pointer;flex-shrink:0;margin-top:3px}
.step-bullet-text{background:none;border:none;outline:none;color:var(--text-dim);font-family:Nunito,sans-serif;font-size:12px;flex:1;min-width:0;resize:none;line-height:1.5;overflow:hidden;field-sizing:content;padding:0}
.step-bullet-text::placeholder{color:var(--text-muted);opacity:0.6}
.step-bullet-text.bullet-done{text-decoration:line-through;opacity:0.4}
.step-bullet-del{background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:13px;line-height:1;padding:0 1px;transition:color 0.15s;margin-top:2px;flex-shrink:0}
.step-bullet-del:hover{color:var(--red)}
.add-bullet{background:none;border:none;color:var(--text-muted);font-family:Nunito,sans-serif;font-size:11px;font-weight:800;cursor:pointer;padding:2px 0;text-align:left;transition:color 0.15s}
.add-bullet:hover{color:var(--accent)}
.step-del{background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:18px;line-height:1;flex-shrink:0;transition:color 0.15s;padding:0 2px}
.step-del:hover{color:var(--red)}
.add-step{background:var(--surface2);border:2px dashed var(--border-strong);border-radius:var(--rl);color:var(--text-muted);font-family:Nunito,sans-serif;font-weight:800;font-size:12px;padding:8px;cursor:pointer;width:100%;transition:all 0.15s}
.add-step:hover{background:var(--surface3);color:var(--text)}

/* B-roll */
.broll-list{display:flex;flex-direction:column;gap:5px}
.broll-item{display:flex;align-items:flex-start;gap:8px;background:var(--surface2);border:2px solid var(--border);border-radius:var(--rl);padding:7px 10px}
.broll-check{width:15px;height:15px;accent-color:var(--accent);cursor:pointer;flex-shrink:0;margin-top:3px}
.broll-text{background:none;border:none;outline:none;color:var(--text);font-family:Nunito,sans-serif;font-size:13px;flex:1;min-width:0;resize:none;line-height:1.5;overflow:hidden;field-sizing:content;padding:0}
.broll-del{background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:15px;line-height:1;transition:color 0.15s;padding:0 2px;margin-top:2px}
.broll-del:hover{color:var(--red)}
.broll-done .broll-text{text-decoration:line-through;color:var(--text-muted)}

/* Sidebar bits */
.slabel{font-size:10px;font-weight:800;letter-spacing:1px;color:var(--text-muted);text-transform:uppercase;margin-bottom:2px}
.ssection{display:flex;flex-direction:column;gap:8px}
.mlabel{font-size:11px;font-weight:700;color:var(--text-muted)}
.minput{background:var(--surface2);border:2px solid var(--border);border-radius:var(--r);padding:7px 10px;color:var(--text);font-family:Nunito,sans-serif;font-size:12px;width:100%;outline:none;transition:border-color 0.15s}
.minput:focus{border-color:var(--border-strong)}
select.minput option{background:var(--surface)}
.status-row{display:flex;gap:5px;flex-wrap:wrap}
.spill{font-size:11px;font-weight:800;padding:4px 10px;border-radius:50px;cursor:pointer;border:2px solid transparent;transition:all 0.15s;font-family:Nunito,sans-serif}
.spill.on{border-color:currentColor}
.si{color:var(--ti-c);background:var(--ti-bg)}
.ss{color:var(--ts-c);background:var(--ts-bg)}
.sf{color:var(--tf-c);background:var(--tf-bg)}
.se{color:var(--te-c);background:var(--te-bg)}
.sp{color:var(--tp-c);background:var(--tp-bg)}

/* Inspo */
.inspo-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.inspo-slot{background:var(--surface2);border:2px dashed var(--border);border-radius:var(--rl);aspect-ratio:16/9;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:11px;color:var(--text-muted);transition:all 0.2s;overflow:hidden;position:relative;flex-direction:column;gap:3px}
.inspo-slot:hover{border-color:var(--border-strong);color:var(--text)}
.inspo-slot img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:calc(var(--rl) - 2px)}
.inspo-del{position:absolute;top:4px;right:4px;background:rgba(0,0,0,0.72);color:#fff;border:none;border-radius:8px;font-size:10px;cursor:pointer;padding:2px 6px;display:none;z-index:2}
.inspo-slot:hover .inspo-del{display:block}

/* Database */
.db-view{flex:1;overflow:hidden;display:flex;flex-direction:column}
.dbtoolbar{padding:12px 18px;border-bottom:2px solid var(--border);display:flex;align-items:center;gap:10px;flex-shrink:0;background:var(--surface)}
.dbsearch{background:var(--surface2);border:2px solid var(--border);border-radius:50px;padding:7px 16px;color:var(--text);font-family:Nunito,sans-serif;font-size:13px;width:210px;outline:none}
.dbsearch:focus{border-color:var(--border-strong)}
.dbfilter{background:var(--surface2);border:2px solid var(--border);border-radius:50px;padding:6px 12px;color:var(--text-dim);font-family:Nunito,sans-serif;font-size:12px;outline:none;cursor:pointer}
.dbcount{margin-left:auto;font-size:12px;color:var(--text-muted);font-weight:800}
.dbgrid{flex:1;overflow-y:auto;padding:18px;display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px;align-content:start}
.vcard{background:var(--surface);border:2px solid var(--border);border-radius:var(--rx);padding:14px;cursor:pointer;transition:all 0.2s;display:flex;flex-direction:column;gap:10px;box-shadow:var(--shadow);position:relative;user-select:none}.vcard.dragging{opacity:0.35;border-style:dashed}.vcard.drag-over{border-color:var(--accent);border-style:solid;transform:translateY(-3px)}
.vcard:hover{border-color:var(--border-strong);transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,0.1)}
body.theme-retro .vcard:hover{box-shadow:0 6px 20px rgba(0,0,0,0.45)}
.vthumb{background:var(--surface3);border-radius:var(--rl);aspect-ratio:16/9;display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative}
.vthumb img{width:100%;height:100%;object-fit:cover;border-radius:calc(var(--rl) - 2px)}
.vthumb-ph{font-size:28px;opacity:0.18}
.vtitle{font-family:Fredoka One,cursive;font-size:15px;color:var(--text);line-height:1.2}
.vconcept{font-size:12px;color:var(--text-dim);line-height:1.5}
.vfooter{display:flex;align-items:center;justify-content:space-between;margin-top:auto;gap:6px;flex-wrap:wrap}
.vstatus{font-size:10px;font-weight:800;padding:3px 9px;border-radius:50px}
.vdate{font-size:11px;color:var(--text-muted);white-space:nowrap}
.vactions{display:flex;gap:6px}
.vbtn{background:var(--surface2);border:2px solid var(--border);border-radius:50px;color:var(--text-dim);font-family:Nunito,sans-serif;font-size:11px;font-weight:800;padding:4px 12px;cursor:pointer;transition:all 0.15s}
.vbtn:hover{border-color:var(--border-strong);color:var(--text)}
.vdel:hover{border-color:var(--red);color:var(--red)}
.dbempty{grid-column:1/-1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;padding:80px;color:var(--text-muted);text-align:center}

/* Calendar */
.cal-view{flex:1;overflow:hidden;display:flex;flex-direction:column}
.caltoolbar{padding:12px 18px;border-bottom:2px solid var(--border);display:flex;align-items:center;gap:12px;background:var(--surface);flex-shrink:0}
.calnav{display:flex;align-items:center;gap:8px}
.calnav button{background:var(--surface2);border:2px solid var(--border);border-radius:50px;color:var(--text);font-family:Nunito,sans-serif;font-size:14px;font-weight:800;padding:5px 14px;cursor:pointer;transition:all 0.15s}
.calnav button:hover{border-color:var(--border-strong)}
.calmonth{font-family:Fredoka One,cursive;font-size:20px;color:var(--text);min-width:168px;text-align:center}
.calleg{margin-left:auto;display:flex;gap:10px;align-items:center}
.calleg-item{display:flex;align-items:center;gap:5px;font-size:12px;color:var(--text-muted);font-weight:700}
.calleg-dot{width:8px;height:8px;border-radius:50%}
.calgridwrap{flex:1;overflow-y:auto;padding:14px 16px}
.calgrid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px}
.caldayh{font-size:10px;font-weight:800;color:var(--text-muted);text-align:center;padding:6px 0;letter-spacing:0.5px;text-transform:uppercase}
.calday{background:var(--surface);border:2px solid var(--border);border-radius:var(--rl);min-height:78px;padding:6px;display:flex;flex-direction:column;gap:3px;transition:border-color 0.15s}
.calday.today{border-color:var(--accent);background:var(--surface3)}
.calday.othermonth{opacity:0.32}
.caldaynum{font-size:11px;font-weight:800;color:var(--text-dim);margin-bottom:2px}
.calevent{border-radius:8px;font-size:10px;font-weight:800;padding:2px 5px;line-height:1.4;white-space:normal;word-break:break-word;cursor:pointer;transition:opacity 0.15s}
.calevent:hover{opacity:0.72}
.calevent.target{background:var(--ti-bg);color:var(--ti-c)}
.calevent.posted{background:var(--tp-bg);color:var(--tp-c)}

/* Modal */
.moverlay{position:fixed;inset:0;background:rgba(0,0,0,0.48);display:flex;align-items:center;justify-content:center;z-index:100;padding:20px}
.modal{background:var(--surface);border:2px solid var(--border-strong);border-radius:var(--rx);width:100%;max-width:490px;max-height:88vh;overflow-y:auto;padding:24px;display:flex;flex-direction:column;gap:14px;box-shadow:0 24px 60px rgba(0,0,0,0.22)}
.mtitle{font-family:Fredoka One,cursive;font-size:22px;color:var(--text)}
.mrow{display:flex;flex-direction:column;gap:5px}
.mlb{font-size:11px;font-weight:800;color:var(--text-muted);letter-spacing:0.5px;text-transform:uppercase}
.minput2{background:var(--surface2);border:2px solid var(--border);border-radius:var(--r);padding:9px 12px;color:var(--text);font-family:Nunito,sans-serif;font-size:13px;width:100%;outline:none;resize:none;transition:border-color 0.15s}
.minput2:focus{border-color:var(--border-strong)}
select.minput2 option{background:var(--surface)}
.mactions{display:flex;gap:8px;justify-content:flex-end;margin-top:4px}

/* Buttons */
.btnp{background:var(--accent);color:var(--accent-text);border:none;border-radius:50px;font-family:Nunito,sans-serif;font-weight:800;font-size:13px;padding:9px 20px;cursor:pointer;transition:opacity 0.15s}
.btnp:hover{opacity:0.85}
.btns{background:var(--surface2);color:var(--text-dim);border:2px solid var(--border);border-radius:50px;font-family:Nunito,sans-serif;font-weight:800;font-size:13px;padding:8px 16px;cursor:pointer;transition:all 0.15s}
.btns:hover{color:var(--text);border-color:var(--border-strong)}
.divider{height:2px;background:var(--border);flex-shrink:0;border-radius:2px}



/* Flow preview */

/* ── Block Editor (Preview = editor) ── */
.be-step{background:var(--surface);border:2px solid var(--border);border-radius:var(--rl);overflow:visible;transition:border-color 0.15s;position:relative;isolation:isolate}
.be-step:focus-within{border-color:var(--border-strong)}
.be-step-header{display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--surface3);border-bottom:1px solid var(--border);cursor:default;border-radius:calc(var(--rl) - 2px) calc(var(--rl) - 2px) 0 0}
.be-step-num{width:26px;height:26px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:900;color:var(--accent-text);flex-shrink:0;border:none;cursor:pointer;transition:all 0.15s}
.be-step-num.done{background:var(--text-muted)}
.be-step-title{font-family:Nunito,sans-serif;font-weight:900;font-size:13px;color:var(--text);background:none;border:none;outline:none;flex:1;padding:0}
.be-step-drag{color:var(--text-muted);cursor:grab;font-size:16px;padding:0 4px;user-select:none}
.be-step-del{background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:16px;padding:0 2px;line-height:1;transition:color 0.15s}
.be-step-del:hover{color:#ff6b6b}
.be-body{padding:10px 14px;outline:none;min-height:48px;font-family:Nunito,sans-serif;font-size:13px;line-height:1.7;color:var(--text);word-break:break-word}
.be-body:empty:before{content:'Click to add notes, bullets, tables…';color:var(--text-muted);pointer-events:none;font-style:italic}
.be-body h1,.be-body h2{font-family:Fredoka One,cursive;color:var(--accent);font-size:15px;font-weight:400;margin:6px 0 2px;line-height:1.3}
.be-body h3{font-weight:900;color:var(--text);font-size:13px;margin:4px 0 2px}
.be-body p{margin:1px 0}
.be-body strong{font-weight:900;color:var(--text)}
.be-body em{color:var(--text-dim);font-style:italic}
.be-body code{background:var(--surface3);padding:1px 5px;border-radius:4px;font-size:11px;font-family:monospace;color:var(--accent)}
.be-body ul,.be-body ol{padding-left:20px;margin:3px 0}.be-body ul.be-checklist{padding-left:0;margin:2px 0;list-style:none}.be-body .be-check-item{display:flex;align-items:center;gap:7px;list-style:none;padding:2px 0;margin:1px 0;outline:none;cursor:text;line-height:1.5;word-break:break-word}.be-body .be-check-item input[type=checkbox]{width:14px;height:14px;flex-shrink:0;margin:0;accent-color:var(--accent);cursor:pointer;-webkit-user-modify:read-only;user-select:none;pointer-events:auto}.be-body .be-check-item span{display:none}
.be-body li{margin:1px 0}
.be-body blockquote{border-left:3px solid var(--accent);margin:4px 0;padding:2px 10px;color:var(--text-dim);font-style:italic}
.be-body hr{border:none;border-top:1px solid var(--border);margin:6px 0;display:block}
.be-body a{color:var(--accent);text-decoration:underline}
.be-body img{max-width:100%;border-radius:var(--r);margin:4px 0;display:block}
/* Tables */
.be-body table{border-collapse:collapse;margin:8px 0;font-size:12px;position:relative}
.be-body th{background:var(--surface3);color:var(--accent);font-weight:900;padding:6px 10px;text-align:left;border:1px solid var(--border-strong);font-size:11px;text-transform:uppercase;letter-spacing:0.5px;position:relative;min-width:60px}
.be-body td{padding:6px 10px;border:1px solid var(--border);color:var(--text);vertical-align:top;position:relative;min-width:60px}
.be-body td:focus,.be-body th:focus{outline:2px solid var(--accent);outline-offset:-2px;background:var(--surface2)}
.be-body tr:nth-child(even) td{background:rgba(255,255,255,0.025)}
/* Table hover controls */
/* Table controls — floating overlay, never inside cells */
.tbl-overlay{position:fixed;z-index:1000;display:flex;gap:2px;pointer-events:auto}
.tbl-overlay.row-ctrl{flex-direction:column}
.tbl-overlay.col-ctrl{flex-direction:row}
.tbl-btn{background:var(--surface3);border:1px solid var(--border);color:var(--text-muted);border-radius:4px;width:20px;height:20px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:10px;font-weight:900;transition:all 0.12s;padding:0;line-height:1}
.tbl-btn:hover{background:var(--accent);color:var(--accent-text);border-color:var(--accent)}
/* Col resize handle */
.col-resize{position:absolute;right:-3px;top:0;bottom:0;width:6px;cursor:col-resize;z-index:20;background:transparent}
.col-resize:hover,.col-resize.dragging{background:var(--accent);opacity:0.5}
/* Add block toolbar */
.be-add-block{display:flex;gap:6px;padding:6px 14px 8px;flex-wrap:wrap}
.be-add-btn{background:var(--surface2);border:1px dashed var(--border);color:var(--text-muted);font-family:Nunito,sans-serif;font-weight:800;font-size:11px;padding:4px 10px;border-radius:50px;cursor:pointer;transition:all 0.12s}
.be-add-btn:hover{border-color:var(--accent);color:var(--accent);background:var(--surface3)}
/* Inline format toolbar */
.be-fmt-bar{position:fixed;background:var(--surface);border:2px solid var(--border-strong);border-radius:8px;padding:4px 6px;display:none;gap:3px;z-index:1000;box-shadow:0 4px 20px rgba(0,0,0,0.3)}
.be-fmt-bar.visible{display:flex}
/* Shortcuts hint */
.be-shortcuts{font-size:10px;color:var(--text-muted);padding:2px 14px 8px;line-height:1.8;font-family:Nunito,sans-serif;border-radius:0 0 calc(var(--rl) - 2px) calc(var(--rl) - 2px)}
.be-body>p:first-child{margin-top:0}.be-body>p:last-child{margin-bottom:0}.be-body>hr+p{margin-top:4px}.be-body>p:has(+hr){margin-bottom:4px}
.be-shortcuts kbd{background:var(--surface3);border:1px solid var(--border);border-radius:3px;padding:1px 5px;font-family:monospace;font-size:10px;color:var(--text-dim)}

.be-fmt-btn{background:none;border:1px solid transparent;color:var(--text-muted);font-family:Nunito,sans-serif;font-weight:800;font-size:11px;padding:3px 7px;border-radius:4px;cursor:pointer;transition:all 0.12s}
.be-fmt-btn:hover{background:var(--surface3);border-color:var(--border);color:var(--text)}

.flow-preview{display:flex;flex-direction:column;gap:16px;padding:4px 0}
.fp-step{background:var(--surface2);border:2px solid var(--border);border-radius:var(--rl);overflow:hidden}
.fp-step-header{display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid var(--border);background:var(--surface3)}
.fp-step-num{width:26px;height:26px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:900;color:var(--accent-text);flex-shrink:0}
.fp-step-num.done{background:var(--text-muted)}
.fp-step-title{font-family:Nunito,sans-serif;font-weight:900;font-size:13px;color:var(--text)}
.fp-step-body{padding:10px 14px;display:flex;flex-direction:column;gap:2px}.flow-preview-rich{display:flex;flex-direction:column;gap:12px}
.fp-check-row{display:flex;align-items:flex-start;gap:9px;padding:5px 0;cursor:pointer;border-radius:6px;transition:opacity 0.2s}
.fp-check-row:hover{background:rgba(255,255,255,0.03)}
.fp-check-label{font-family:Nunito,sans-serif;font-size:13px;color:var(--text-dim);line-height:1.5;transition:text-decoration 0.15s}

.fp-step-body .step-rich{padding:0;min-height:0}

/* Rich step editor */
.step-rich{
  outline:none;
  min-height:60px;
  padding:6px 2px;
  font-family:Nunito,sans-serif;
  font-size:13px;
  line-height:1.7;
  color:var(--text);
  white-space:pre-wrap;
  word-break:break-word;
  cursor:text;
}
.step-rich:empty:before{content:attr(data-placeholder);color:var(--text-muted);pointer-events:none}
.step-rich h1,.step-rich h2{font-family:Fredoka One,cursive;color:var(--accent);margin:6px 0 2px;font-size:15px;font-weight:400;line-height:1.3}
.step-rich h3{font-family:Nunito,sans-serif;font-weight:900;color:var(--text);margin:4px 0 2px;font-size:13px}
.step-rich p{margin:1px 0}
.step-rich strong{color:var(--text);font-weight:900}
.step-rich em{color:var(--text-dim);font-style:italic}
.step-rich code{background:var(--surface3);padding:1px 5px;border-radius:4px;font-size:11px;font-family:monospace;color:var(--accent)}
.step-rich ul,.step-rich ol{padding-left:18px;margin:3px 0}
.step-rich li{margin:1px 0}
.step-rich li.done-item{text-decoration:line-through;opacity:0.5}
.step-rich blockquote{border-left:3px solid var(--accent);margin:4px 0;padding:2px 10px;color:var(--text-dim);font-style:italic}
.step-rich hr{border:none;border-top:1px solid var(--border);margin:8px 0}
.step-rich a{color:var(--accent);text-decoration:underline}
.step-rich img{max-width:100%;border-radius:var(--r);margin:4px 0;display:block}
/* Tables */
.step-rich table{width:100%;border-collapse:collapse;margin:8px 0;font-size:12px}
.step-rich th{background:var(--surface3);color:var(--accent);font-weight:900;padding:6px 10px;text-align:left;border:1px solid var(--border-strong);font-size:11px;text-transform:uppercase;letter-spacing:0.5px}
.step-rich td{padding:6px 10px;border:1px solid var(--border);color:var(--text-dim);vertical-align:top;line-height:1.5}
.step-rich tr:nth-child(even) td{background:rgba(255,255,255,0.025)}
/* Toolbar */
.rich-toolbar{display:none}
.rtb{background:none;border:1px solid transparent;border-radius:4px;color:var(--text-muted);font-family:Nunito,sans-serif;font-weight:800;font-size:11px;padding:2px 6px;cursor:pointer;transition:all 0.12s;line-height:1.4}
.rtb:hover{background:var(--surface3);border-color:var(--border);color:var(--text)}
.rtb.active{background:var(--surface3);border-color:var(--border-strong);color:var(--accent)}
.rtb-sep{width:1px;background:var(--border);margin:0 2px;align-self:stretch}
.step-editor-wrap{border:1px solid var(--border);border-radius:var(--r);background:var(--surface2);overflow:hidden;transition:border-color 0.15s}
.step-editor-wrap:focus-within{border-color:var(--border-strong)}
.wysiwyg{outline:none;min-height:80px;padding:8px 10px;font-family:Nunito,sans-serif;font-size:13px;line-height:1.7;color:var(--text);word-break:break-word;cursor:text}
.wysiwyg:empty:before{content:attr(data-ph);color:var(--text-muted);pointer-events:none;font-style:italic}
.wysiwyg h1,.wysiwyg h2{font-family:Fredoka One,cursive;color:var(--accent);font-size:15px;font-weight:400;margin:6px 0 2px;line-height:1.3;display:block}
.wysiwyg h3{font-weight:900;color:var(--text);font-size:13px;margin:4px 0 2px;display:block}
.wysiwyg p{margin:1px 0;display:block}
.wysiwyg strong{font-weight:900;color:var(--text)}
.wysiwyg em{color:var(--text-dim);font-style:italic}
.wysiwyg code{background:var(--surface3);padding:1px 5px;border-radius:4px;font-size:11px;font-family:monospace;color:var(--accent)}
.wysiwyg ul,.wysiwyg ol{padding-left:20px;margin:3px 0}
.wysiwyg li{margin:1px 0}
.wysiwyg blockquote{border-left:3px solid var(--accent);margin:4px 0;padding:2px 10px;color:var(--text-dim);font-style:italic}
.wysiwyg hr{border:none;border-top:1px solid var(--border);margin:8px 0}
.wysiwyg table{width:100%;border-collapse:collapse;margin:6px 0;font-size:12px}
.wysiwyg th{background:var(--surface3);color:var(--accent);font-weight:900;padding:5px 9px;text-align:left;border:1px solid var(--border-strong);font-size:11px;text-transform:uppercase;letter-spacing:0.5px}
.wysiwyg td{padding:5px 9px;border:1px solid var(--border);color:var(--text-dim);vertical-align:top}
.wysiwyg tr:nth-child(even) td{background:rgba(255,255,255,0.025)}
.wysiwyg a{color:var(--accent);text-decoration:underline}
.wysiwyg img{max-width:100%;border-radius:var(--r);margin:4px 0;display:block}

/* Notes renderer */
.notes-rendered{background:var(--surface2);border:2px solid var(--border);border-radius:var(--r);padding:12px 14px;font-size:12px;line-height:1.7;color:var(--text);min-height:80px;overflow-x:auto}
.notes-rendered h2,.notes-rendered h3{font-family:Fredoka One,cursive;color:var(--accent);margin:10px 0 4px;font-size:14px}
.notes-rendered h3{font-size:13px;color:var(--text-dim)}
.notes-rendered p{margin:3px 0;color:var(--text-dim)}
.notes-rendered strong{color:var(--text);font-weight:800}
.notes-rendered ul,.notes-rendered ol{padding-left:16px;margin:4px 0}
.notes-rendered li{margin:2px 0;color:var(--text-dim)}
.notes-rendered table{width:100%;border-collapse:collapse;margin:8px 0;font-size:11px}
.notes-rendered th{background:var(--surface3);color:var(--accent);font-weight:900;padding:6px 10px;text-align:left;border:1px solid var(--border-strong);font-size:10px;text-transform:uppercase;letter-spacing:0.5px}
.notes-rendered td{padding:6px 10px;border:1px solid var(--border);color:var(--text-dim);vertical-align:top}
.notes-rendered tr:nth-child(even) td{background:rgba(255,255,255,0.025)}
.notes-rendered a{color:var(--accent);text-decoration:none}
.notes-rendered hr{border:none;border-top:1px solid var(--border);margin:8px 0}
.notes-mode-toggle{display:flex;gap:4px}
.notes-mode-btn{background:none;border:1px solid var(--border);border-radius:50px;color:var(--text-muted);font-family:Nunito,sans-serif;font-weight:800;font-size:10px;padding:2px 9px;cursor:pointer;transition:all 0.15s}
.notes-mode-btn.active{background:var(--surface3);border-color:var(--border-strong);color:var(--text)}

/* Idea Dump */
.dump-wrap{flex:1;overflow-y:auto;display:flex;flex-direction:column;align-items:center;padding:32px 20px;gap:20px}
.dump-box{width:100%;max-width:680px;background:var(--surface);border:2px solid var(--border);border-radius:var(--rx);padding:24px;display:flex;flex-direction:column;gap:14px;box-shadow:var(--shadow)}
.dump-title{font-family:Fredoka One,cursive;font-size:20px;color:var(--text)}
.dump-sub{font-size:13px;color:var(--text-dim);line-height:1.6}
.dump-textarea{background:var(--surface2);border:2px solid var(--border);border-radius:var(--rl);padding:14px 16px;color:var(--text);font-family:Nunito,sans-serif;font-size:14px;width:100%;outline:none;resize:vertical;line-height:1.7;transition:border-color 0.15s;min-height:110px;overflow:hidden;field-sizing:content}
.dump-textarea:focus{border-color:var(--border-strong)}
.dump-textarea::placeholder{color:var(--text-muted)}
.dump-actions{display:flex;align-items:center;gap:10px}
.dump-btn{background:var(--accent);color:var(--accent-text);border:none;font-family:Nunito,sans-serif;font-weight:800;font-size:14px;padding:10px 24px;border-radius:50px;cursor:pointer;transition:opacity 0.15s;box-shadow:0 2px 8px rgba(0,0,0,0.1)}
.dump-btn:hover{opacity:0.85}
.dump-btn:disabled{opacity:0.5;cursor:not-allowed}
.dump-status{font-size:12px;color:var(--text-muted);font-weight:700}
.dump-result{width:100%;max-width:680px;background:var(--surface);border:2px solid var(--border-strong);border-radius:var(--rx);padding:24px;display:flex;flex-direction:column;gap:16px;box-shadow:var(--shadow)}
.dump-result-title{font-family:Fredoka One,cursive;font-size:18px;color:var(--text)}
.dump-field-group{display:flex;flex-direction:column;gap:5px}
.dump-field-label{font-size:10px;font-weight:800;letter-spacing:1px;color:var(--text-muted);text-transform:uppercase}
.dump-field-val{font-size:13px;color:var(--text-dim);line-height:1.6;background:var(--surface2);border-radius:var(--r);padding:8px 12px;border:1px solid var(--border)}
.dump-steps-list{display:flex;flex-direction:column;gap:5px}
.dump-step-row{display:flex;gap:8px;align-items:flex-start;font-size:13px;color:var(--text-dim);line-height:1.5}
.dump-step-n{width:22px;height:22px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;color:var(--accent-text);flex-shrink:0;margin-top:1px}
.dump-broll-list{display:flex;flex-direction:column;gap:4px}
.dump-broll-item{font-size:13px;color:var(--text-dim);padding:2px 0;display:flex;align-items:center;gap:6px}
.dump-broll-item::before{content:'📹';font-size:11px}
.dump-add-btn{background:var(--green);color:#fff;border:none;font-family:Nunito,sans-serif;font-weight:800;font-size:13px;padding:9px 20px;border-radius:50px;cursor:pointer;transition:opacity 0.15s;align-self:flex-start}
.dump-add-btn:hover{opacity:0.85}
.dump-discard-btn{background:var(--surface2);color:var(--text-dim);border:2px solid var(--border);font-family:Nunito,sans-serif;font-weight:800;font-size:13px;padding:8px 18px;border-radius:50px;cursor:pointer;transition:all 0.15s}
.dump-discard-btn:hover{border-color:var(--red);color:var(--red)}
.dump-result-actions{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
.hidden{display:none!important}
input[type="file"]{display:none}

/* ── MOBILE ── */
@media(max-width:700px){
  .nav{height:auto;flex-wrap:wrap;padding:8px 10px;gap:6px}
  .nav-logo{font-size:15px;padding:3px 10px}
  .nav-sub{display:none}
  .nav-tabs{order:3;width:100%;gap:3px;overflow-x:auto;flex-wrap:nowrap;padding-bottom:2px}
  .nav-tab{font-size:11px;padding:4px 10px;white-space:nowrap;flex-shrink:0}
  .nav-right{gap:5px}
  .theme-btn{font-size:10px;padding:4px 8px}
  .nav-add{font-size:12px;padding:6px 12px}

  .planner{grid-template-columns:1fr;overflow:visible}
  .planner-main{border-right:none;border-bottom:2px solid var(--border);padding:12px}
  .planner-sidebar{padding:12px}
  .planner-topbar{padding:8px 10px;flex-wrap:wrap;gap:6px}
  .planner-cur-title{font-size:13px;max-width:200px}

  .hero-title-input,.htitle{font-size:20px}
  .step{padding:8px 10px}
  .step-num{width:32px;height:32px;font-size:14px;flex-shrink:0}

  .dbgrid{grid-template-columns:1fr;padding:12px}
  .calgrid{gap:2px}
  .calday{min-height:50px;padding:4px}
  .caldaynum{font-size:10px}
  .calevent{font-size:9px;padding:1px 3px}
  .cal-month-title{font-size:16px;min-width:120px}

  .dump-wrap{padding:16px 12px}
  .dump-box,.dump-result{padding:16px}

  .modal{padding:16px;margin:0}
  .moverlay{padding:10px;align-items:flex-end}
  .modal{border-radius:var(--rx) var(--rx) 0 0;max-height:92vh}

  .planner-sidebar{display:none}
  .planner-sidebar.mob-open{display:flex}
  .mob-sidebar-toggle{display:flex}
}
@media(min-width:701px){
  .mob-sidebar-toggle{display:none!important}
  .planner-sidebar{display:flex!important}
}
.mob-sidebar-toggle{
  background:var(--surface2);border:2px solid var(--border);
  color:var(--text-dim);font-family:Nunito,sans-serif;font-weight:800;font-size:12px;
  padding:5px 12px;border-radius:50px;cursor:pointer;transition:all 0.15s;
  align-items:center;gap:5px;margin:0 12px 12px;align-self:flex-start;
}
.mob-sidebar-toggle:hover{border-color:var(--border-strong);color:var(--text)}
</style>
