function changeMonth(d){calMonth=new Date(calMonth.getFullYear(),calMonth.getMonth()+d,1);renderCalendar()}
function renderCalendar(){
  const yr=calMonth.getFullYear(),mo=calMonth.getMonth();
  document.getElementById('cal-title').textContent=MONTHS[mo]+' '+yr;
  const g=document.getElementById('cal-grid');g.innerHTML='';
  ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'].forEach(d=>{const h=document.createElement('div');h.className='caldayh';h.textContent=d;g.appendChild(h)});
  const fd=(()=>{let d=new Date(yr,mo,1).getDay();return d===0?6:d-1})();
  const tot=new Date(yr,mo+1,0).getDate(),prev=new Date(yr,mo,0).getDate();
  const today=new Date(),evts={};
  videos.forEach(v=>{
    if(v.targetDate){if(!evts[v.targetDate])evts[v.targetDate]=[];evts[v.targetDate].push({type:'target',title:v.title,id:v.id,status:v.status})}
    if(v.postedDate){if(!evts[v.postedDate])evts[v.postedDate]=[];evts[v.postedDate].push({type:'posted',title:v.title,id:v.id,status:v.status})}
  });
  for(let i=0;i<fd;i++){const d=document.createElement('div');d.className='calday othermonth';d.innerHTML=`<div class="caldaynum">${prev-fd+1+i}</div>`;g.appendChild(d)}
  for(let d=1;d<=tot;d++){
    const ds=yr+'-'+String(mo+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
    const el=document.createElement('div');el.className='calday';
    if(today.getFullYear()===yr&&today.getMonth()===mo&&today.getDate()===d)el.classList.add('today');
    let h=`<div class="caldaynum">${d}</div>`;
    if(evts[ds])evts[ds].forEach(ev=>{const ss=statusStyle(ev.status);h+=`<div class="calevent" style="${ss}" onclick="openCard('${ev.id}')" title="${esc(ev.title)}">${ev.type==='target'?'🎯':'✅'} ${esc(ev.title)}</div>`});
    el.innerHTML=h;g.appendChild(el);
  }
  const rem=(7-((fd+tot)%7))%7;
  for(let d=1;d<=rem;d++){const el=document.createElement('div');el.className='calday othermonth';el.innerHTML=`<div class="caldaynum">${d}</div>`;g.appendChild(el)}
}


