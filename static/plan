// ── Table overlay: single persistent panel per table ─────────
var _tblRegistry = {};
var _tblIdCounter = 0;

// One row-ctrl and one col-ctrl panel live *inside* the table wrapper
// so they stay in the same stacking context and never flicker.
function beInjectTableControls(tbl){
  if(!tbl._beId){ tbl._beId = 'tbl_'+(++_tblIdCounter); }
  _tblRegistry[tbl._beId] = tbl;
  // Ensure parent is position:relative for absolute children
  tbl.style.position = 'relative';
  // Remove any previous panels
  var prev = tbl.parentElement && tbl.parentElement.querySelectorAll('.tbl-row-panel,.tbl-col-panel,.col-resize');
  if(prev) prev.forEach(function(el){el.remove();});
  // Make all cells editable
  tbl.querySelectorAll('td,th').forEach(function(c){ c.contentEditable='true'; });

  // ── Shared panels (one per table, repositioned on hover) ──
  var rowPanel = document.createElement('div');
  rowPanel.className = 'tbl-row-panel';
  rowPanel.style.cssText = 'position:absolute;left:-60px;top:0;display:none;flex-direction:column;gap:2px;z-index:100;background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:3px;box-shadow:0 2px 8px rgba(0,0,0,0.3)';
  rowPanel.innerHTML =
    '<button class="tbl-btn" title="Row above" onclick="beTableRowAbove(event)">&uarr;+</button>'
   +'<button class="tbl-btn" title="Row below" onclick="beTableRowBelow(event)">+&darr;</button>'
   +'<button class="tbl-btn" title="Delete row" onclick="beTableRowDelete(event)" style="color:#ff6b6b">&#215;</button>';
  tbl.parentElement.insertBefore(rowPanel, tbl);

  var colPanel = document.createElement('div');
  colPanel.className = 'tbl-col-panel';
  colPanel.style.cssText = 'position:absolute;top:-34px;left:0;display:none;flex-direction:row;gap:2px;z-index:100;background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:3px;box-shadow:0 2px 8px rgba(0,0,0,0.3)';
  colPanel.innerHTML =
    '<button class="tbl-btn" title="Col left" onclick="beTableColLeft(event)">+&larr;</button>'
   +'<button class="tbl-btn" title="Del col" onclick="beTableColDelete(event)" style="color:#ff6b6b">&#215;</button>'
   +'<button class="tbl-btn" title="Col right" onclick="beTableColRight(event)">&rarr;+</button>'
   +'<div style="width:1px;background:var(--border);margin:0 2px"></div>'
   +'<button class="tbl-btn" title="Delete entire table" onclick="beTableDelete(event)" style="color:#ff6b6b;font-size:9px;width:auto;padding:0 5px">&#128465; table</button>';
  tbl.parentElement.insertBefore(colPanel, tbl);

  // Store references on the table element
  tbl._rowPanel = rowPanel;
  tbl._colPanel = colPanel;
  rowPanel._tbl = tbl;
  colPanel._tbl = tbl;

  // ── Row hover: reposition row panel ──
  var _rowTimer = null;
  function hideRowPanel(){ _rowTimer = setTimeout(function(){ rowPanel.style.display='none'; }, 300); }
  function showRowPanel(row){
    clearTimeout(_rowTimer);
    var tRect = tbl.getBoundingClientRect();
    var rRect = row.getBoundingClientRect();
    rowPanel.dataset.rowIdx = row.rowIndex;
    rowPanel.style.top = (rRect.top - tRect.top + window.scrollY) + 'px';
    rowPanel.style.display = 'flex';
  }
  Array.from(tbl.rows).forEach(function(row){
    row.addEventListener('mouseenter', function(){ showRowPanel(row); });
    row.addEventListener('mouseleave', hideRowPanel);
  });
  rowPanel.addEventListener('mouseenter', function(){ clearTimeout(_rowTimer); });
  rowPanel.addEventListener('mouseleave', hideRowPanel);

  // ── Header cell hover: reposition col panel ──
  var _colTimer = null;
  function hideColPanel(){ _colTimer = setTimeout(function(){ colPanel.style.display='none'; }, 300); }
  function showColPanel(cell){
    clearTimeout(_colTimer);
    var tRect = tbl.getBoundingClientRect();
    var cRect = cell.getBoundingClientRect();
    colPanel.dataset.colIdx = cell.cellIndex;
    colPanel.style.left = (cRect.left - tRect.left) + 'px';
    colPanel.style.display = 'flex';
  }
  if(tbl.rows[0]){
    Array.from(tbl.rows[0].cells).forEach(function(cell){
      cell.addEventListener('mouseenter', function(){ showColPanel(cell); });
      cell.addEventListener('mouseleave', hideColPanel);
      // Resize handle — on the wrapper, not inside the cell
      var rh = document.createElement('div'); rh.className = 'col-resize';
      rh.style.cssText = 'position:absolute;right:-3px;top:0;bottom:0;width:6px;cursor:col-resize;z-index:20;background:transparent;pointer-events:auto';
      rh.addEventListener('mousedown', function(e){ beStartColResize(e, cell, tbl); });
      // Append to wrapper, positioned relative to cell
      (function(c,r){
        var wrap = tbl.closest('.tbl-wrap')||tbl.parentElement;
        // We can't easily position relative to a cell from the wrapper,
        // so keep it in the cell but mark it so serializer skips it
        r.setAttribute('data-ctrl','1');
        c.appendChild(r);
      })(cell, rh);
    });
    colPanel.addEventListener('mouseenter', function(){ clearTimeout(_colTimer); });
    colPanel.addEventListener('mouseleave', hideColPanel);
  }
}

